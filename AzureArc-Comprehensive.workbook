                  "name": "linben-update-pie"
                },
                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.osType == 'linux'\n| extend configured = isnotnull(properties.osProfile.linuxConfiguration.patchSettings)\n| extend osSku = tostring(properties.osSku)\n| project Name = name, resourceGroup, osSku, Status = tostring(properties.status), UpdateMgr = iff(configured, 'Configured', 'Not Configured')\n| order by UpdateMgr desc, Name asc",
                    "size": 0,
                    "title": "Server Details",
