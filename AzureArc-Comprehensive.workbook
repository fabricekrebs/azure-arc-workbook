{
  "version": "Notebook/1.0",
  "items": [
    {
      "type": 1,
      "content": {
        "json": "# Azure Arc Comprehensive Dashboard\n\nUnified view of Azure Arc-enabled **Windows Servers**, **Linux Servers**, and **SQL Server** instances across your environment.\n\n> Enable *Show Cost Analysis* to see potential savings estimates for Arc capabilities."
      },
      "name": "workbook-header"
    },
    {
      "type": 9,
      "content": {
        "version": "KqlParameterItem/1.0",
        "crossComponentResources": [
          "{Subscriptions}"
        ],
        "parameters": [
          {
            "id": "b3a82c40-0001-4a00-8000-000000000001",
            "version": "KqlParameterItem/1.0",
            "name": "Subscriptions",
            "type": 6,
            "multiSelect": true,
            "quote": "'",
            "delimiter": ",",
            "typeSettings": {
              "additionalResourceOptions": [
                "value::all"
              ],
              "includeAll": true,
              "showDefault": false
            },
            "defaultValue": "value::all"
          },
          {
            "id": "b3a82c40-0001-4a00-8000-000000000003",
            "version": "KqlParameterItem/1.0",
            "name": "ShowCostAnalysis",
            "label": "Show Cost Analysis",
            "type": 10,
            "typeSettings": {
              "additionalResourceOptions": [],
              "showDefault": false
            },
            "jsonData": "[\"No\", \"Yes\"]",
            "value": "No"
          }
        ],
        "style": "pills",
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources"
      },
      "name": "global-parameters"
    },
    {
      "type": 9,
      "content": {
        "version": "KqlParameterItem/1.0",
        "parameters": [
          {
