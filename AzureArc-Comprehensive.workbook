          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type in ({WinExtMachineType})\n| extend JoinID = toupper(id),\n    OSName = iff(type == 'microsoft.hybridcompute/machines', tostring(properties.osProfile.computerName), tostring(properties.extended.instanceView.computerName)),\n    OSType = iff(type == 'microsoft.hybridcompute/machines', tostring(properties.osName), tolower(tostring(properties.storageProfile.osDisk.osType))),\n    OSsku = iff(type == 'microsoft.hybridcompute/machines', tostring(properties.osSku), tostring(properties.extended.instanceView.osName)),\n    ServerStatus = iff(type == 'microsoft.hybridcompute/machines', tostring(properties.status), tostring(properties.extended.instanceView.powerState.displayStatus))\n| where ServerStatus in ({WinExtServerStatus})\n| join kind=leftouter (\n    resources\n    | where type == 'microsoft.hybridcompute/machines/extensions' or type == 'microsoft.compute/virtualmachines/extensions'\n    | where properties.type in ('{WinExtension1:value}','{WinExtension2:value}','{WinExtension3:value}','{WinExtension4:value}')\n    | extend VMId = toupper(substring(id, 0, indexof(id, '/extensions'))),\n        ExtensionName = tostring(properties.type),\n        Version = iff(type == 'microsoft.hybridcompute/machines/extensions', tostring(properties.instanceView.typeHandlerVersion), tostring(properties.typeHandlerVersion)),\n        Status = tostring(properties.provisioningState)\n) on $left.JoinID == $right.VMId\n| where OSType contains 'windows' or OSsku contains 'Windows'\n| extend ServerName = id, VersionNumber = pack(ExtensionName, Version), ProvisionState = pack(ExtensionName, Status)\n| summarize ExtVersions = make_bag(VersionNumber), ExtProvision = make_bag(ProvisionState) by ServerName, OSType, OSName, OSsku, ServerStatus\n| extend Extension1Version = tostring(parse_json(ExtVersions)['{WinExtension1:value}']),\n    ['1-{WinExtension1:value}'] = iff(isnotnull(parse_json(ExtProvision)['{WinExtension1:value}']), parse_json(ExtProvision)['{WinExtension1:value}'], ''),\n    Extension2Version = tostring(parse_json(ExtVersions)['{WinExtension2:value}']),\n    ['2-{WinExtension2:value}'] = iff(isnotnull(parse_json(ExtProvision)['{WinExtension2:value}']), parse_json(ExtProvision)['{WinExtension2:value}'], ''),\n    Extension3Version = tostring(parse_json(ExtVersions)['{WinExtension3:value}']),\n    ['3-{WinExtension3:value}'] = iff(isnotnull(parse_json(ExtProvision)['{WinExtension3:value}']), parse_json(ExtProvision)['{WinExtension3:value}'], ''),\n    Extension4Version = tostring(parse_json(ExtVersions)['{WinExtension4:value}']),\n    ['4-{WinExtension4:value}'] = iff(isnotnull(parse_json(ExtProvision)['{WinExtension4:value}']), parse_json(ExtProvision)['{WinExtension4:value}'], '')\n| project ServerName, OSsku, ServerStatus, OSType, ['1-{WinExtension1:value}'], Extension1Version, ['2-{WinExtension2:value}'], Extension2Version, ['3-{WinExtension3:value}'], Extension3Version, ['4-{WinExtension4:value}'], Extension4Version\n| sort by Extension1Version",
              "size": 2,
              "title": "Windows Extension Details",
