                          "formatOptions": {
                            "linkTarget": "Resource",
                            "showIcon": true
                          }
                        },
                        {
                          "columnMatch": "BPA",
                          "formatter": 18,
                          "formatOptions": {
                            "thresholdsOptions": "icons",
                            "thresholdsGrid": [
                              {
                                "operator": "==",
                                "thresholdValue": "Configured",
                                "representation": "success",
                                "text": "{0}"
                              },
                              {
                                "operator": "Default",
                                "thresholdValue": null,
                                "representation": "warning",
                                "text": "{0}"
                              }
                            ]
                          }
                        }
                      ],
                      "rowLimit": 2000,
                      "filter": true
                    }
                  },
                  "customWidth": "60",
                  "name": "sql-bpa-grid"
                }
              ]
            },
            "conditionalVisibility": {
              "parameterName": "sqlSubTab",
              "comparison": "isEqualTo",
              "value": "sqlBpa"
            },
            "name": "sql-bpa-ben-group"
          },
          {
            "type": 12,
            "content": {
              "version": "NotebookGroup/1.0",
              "groupType": "editable",
              "items": [
                {
                  "type": 1,
                  "content": {
                    "json": "### Performance Monitoring\nSQL instances with Azure Monitor Agent configured for performance data collection."
                  }
                },
                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "resources\n| where type == 'microsoft.azurearcdata/sqlserverinstances'\n| extend monitoringEnabled = tostring(properties.monitoring.enabled)\n| extend Status = iff(monitoringEnabled == 'true', 'Configured', 'Not Configured')\n| summarize count() by Status",
                    "size": 3,
                    "title": "Performance Monitoring Status",
                    "queryType": 1,
