    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 1,
            "content": {
              "json": "## Windows Extensions Monitor\nTrack extension deployment status across Arc-enabled Windows servers and Azure VMs. Select up to 4 extensions to compare."
            },
            "name": "extwin-header"
          },
          {
            "type": 9,
            "content": {
              "version": "KqlParameterItem/1.0",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "parameters": [
                {
                  "id": "d3a82c40-0005-4a00-8000-000000000001",
                  "version": "KqlParameterItem/1.0",
                  "name": "WinExtSubscriptions",
                  "label": "Subscriptions",
                  "type": 6,
                  "multiSelect": true,
                  "quote": "'",
                  "delimiter": ",",
                  "typeSettings": {
                    "additionalResourceOptions": [
                      "value::all"
                    ],
                    "includeAll": true
                  },
                  "defaultValue": "value::all"
                },
                {
                  "id": "d3a82c40-0005-4a00-8000-000000000002",
                  "version": "KqlParameterItem/1.0",
                  "name": "WinExtMachineType",
                  "label": "Machine Type",
                  "type": 2,
                  "isRequired": true,
                  "multiSelect": true,
                  "quote": "'",
                  "delimiter": ",",
                  "value": [
                    "value::all"
                  ],
                  "typeSettings": {
                    "additionalResourceOptions": [
                      "value::all"
                    ],
                    "showDefault": false
                  },
                  "jsonData": "[\n  {\"value\": \"microsoft.hybridcompute/machines\", \"label\": \"Azure Arc Servers\"},\n  {\"value\": \"microsoft.compute/virtualmachines\", \"label\": \"Azure VMs\"}\n]",
                  "defaultValue": "value::all"
                },
                {
                  "id": "d3a82c40-0005-4a00-8000-000000000003",
                  "version": "KqlParameterItem/1.0",
                  "name": "WinExtServerStatus",
                  "label": "Server Status",
                  "type": 2,
                  "multiSelect": true,
                  "quote": "'",
                  "delimiter": ",",
                  "query": "resources\n| where type == 'microsoft.compute/virtualmachines' or type == 'microsoft.hybridcompute/machines'\n| extend ServerStatus = iff(type == 'microsoft.hybridcompute/machines', tostring(properties.status), tostring(properties.extended.instanceView.powerState.displayStatus))\n| distinct ServerStatus",
                  "crossComponentResources": [
                    "value::all"
                  ],
                  "typeSettings": {
                    "additionalResourceOptions": [
                      "value::all"
                    ],
                    "showDefault": false
                  },
                  "defaultValue": "value::all",
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources"
                }
              ],
              "style": "pills",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources"
            },
            "name": "extwin-params"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines/extensions' or type == 'microsoft.compute/virtualmachines/extensions'\n| extend ExtensionName = tostring(properties.type)\n| distinct ExtensionName\n| where ExtensionName !contains 'Linux'",
              "size": 0,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{WinExtSubscriptions}"
              ]
            },
            "conditionalVisibility": {
              "parameterName": "Hidden",
              "comparison": "isEqualTo",
              "value": "true"
            },
            "name": "DiscoveredExtensionWindows"
          },
          {
            "type": 9,
            "content": {
              "version": "KqlParameterItem/1.0",
              "parameters": [
                {
                  "id": "d3a82c40-0005-4a00-8000-000000000010",
                  "version": "KqlParameterItem/1.0",
                  "name": "WinExtension1",
                  "label": "Extension 1",
                  "type": 2,
                  "query": "{\"version\":\"Merge/1.0\",\"merges\":[{\"id\":\"16c11101-93b9-4d76-87ee-c65bb60d00e4\",\"mergeType\":\"table\",\"leftTable\":\"DiscoveredExtensionWindows\"}],\"projectRename\":[{\"originalName\":\"[DiscoveredExtensionWindows].ExtensionName\",\"mergedName\":\"ExtensionName\",\"fromId\":\"16c11101-93b9-4d76-87ee-c65bb60d00e4\"}]}",
                  "typeSettings": {
                    "additionalResourceOptions": [],
                    "showDefault": false
                  },
                  "queryType": 7,
                  "value": "AzureMonitorWindowsAgent"
                },
                {
                  "id": "d3a82c40-0005-4a00-8000-000000000011",
                  "version": "KqlParameterItem/1.0",
                  "name": "WinExtension2",
                  "label": "Extension 2",
                  "type": 2,
                  "query": "{\"version\":\"Merge/1.0\",\"merges\":[{\"id\":\"16c11101-93b9-4d76-87ee-c65bb60d00e8\",\"mergeType\":\"table\",\"leftTable\":\"DiscoveredExtensionWindows\"}],\"projectRename\":[{\"originalName\":\"[DiscoveredExtensionWindows].ExtensionName\",\"mergedName\":\"ExtensionName\",\"fromId\":\"16c11101-93b9-4d76-87ee-c65bb60d00e8\"}]}",
                  "typeSettings": {
                    "additionalResourceOptions": [],
                    "showDefault": false
                  },
                  "queryType": 7,
                  "value": "AzureSecurityWindowsAgent"
                },
                {
                  "id": "d3a82c40-0005-4a00-8000-000000000012",
                  "version": "KqlParameterItem/1.0",
                  "name": "WinExtension3",
                  "label": "Extension 3",
                  "type": 2,
                  "query": "{\"version\":\"Merge/1.0\",\"merges\":[{\"id\":\"16c11101-93b9-4d76-87ee-c65bb60d00ea\",\"mergeType\":\"table\",\"leftTable\":\"DiscoveredExtensionWindows\"}],\"projectRename\":[{\"originalName\":\"[DiscoveredExtensionWindows].ExtensionName\",\"mergedName\":\"ExtensionName\",\"fromId\":\"16c11101-93b9-4d76-87ee-c65bb60d00ea\"}]}",
                  "typeSettings": {
                    "additionalResourceOptions": [],
                    "showDefault": false
                  },
                  "queryType": 7,
                  "value": "CustomScriptExtension"
                },
                {
                  "id": "d3a82c40-0005-4a00-8000-000000000013",
                  "version": "KqlParameterItem/1.0",
                  "name": "WinExtension4",
                  "label": "Extension 4",
                  "type": 2,
                  "query": "{\"version\":\"Merge/1.0\",\"merges\":[{\"id\":\"16c11101-93b9-4d76-87ee-c65bb60d00ec\",\"mergeType\":\"table\",\"leftTable\":\"DiscoveredExtensionWindows\"}],\"projectRename\":[{\"originalName\":\"[DiscoveredExtensionWindows].ExtensionName\",\"mergedName\":\"ExtensionName\",\"fromId\":\"16c11101-93b9-4d76-87ee-c65bb60d00ec\"}]}",
                  "typeSettings": {
                    "additionalResourceOptions": [],
                    "showDefault": false
                  },
                  "queryType": 7,
                  "value": "WindowsAgent.SqlServer"
                }
              ],
              "style": "pills",
              "queryType": 7
            },
            "name": "extwin-extension-params"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type in ({WinExtMachineType})\n| extend JoinID = toupper(id), OSType = iff(type == 'microsoft.hybridcompute/machines', tostring(properties.osType), tolower(tostring(properties.storageProfile.osDisk.osType))), ServerStatus = iff(type == 'microsoft.hybridcompute/machines', tostring(properties.status), tostring(properties.extended.instanceView.powerState.displayStatus))\n| where ServerStatus in ({WinExtServerStatus})\n| join kind=leftouter (\n    resources\n    | where type == 'microsoft.hybridcompute/machines/extensions' or type == 'microsoft.compute/virtualmachines/extensions'\n    | where properties.type in ('{WinExtension1:value}')\n    | extend VMId = toupper(substring(id, 0, indexof(id, '/extensions'))), ExtensionName = tostring(properties.type), Status = tostring(properties.provisioningState)\n) on $left.JoinID == $right.VMId\n| where OSType in ('windows')\n| extend Serverid = id, ProvisionState = pack(ExtensionName, Status)\n| summarize ExtProvision = make_bag(ProvisionState) by Serverid, OSType, ServerStatus\n| extend status = parse_json(ExtProvision)['{WinExtension1:value}']\n| project status\n| summarize count() by tostring(status)",
              "size": 3,
              "title": "{WinExtension1:value}",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{WinExtSubscriptions}"
              ],
              "visualization": "piechart",
              "chartSettings": {
                "seriesLabelSettings": [
                  {
                    "seriesName": "Succeeded",
                    "color": "green"
                  },
                  {
                    "seriesName": "",
                    "label": "Not Present",
                    "color": "gray"
                  },
                  {
                    "seriesName": "Failed",
                    "color": "red"
                  },
                  {
                    "seriesName": "Deleting",
                    "color": "redBright"
                  }
                ]
              }
            },
            "customWidth": "25",
            "name": "extwin-pie1"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type in ({WinExtMachineType})\n| extend JoinID = toupper(id), OSType = iff(type == 'microsoft.hybridcompute/machines', tostring(properties.osType), tolower(tostring(properties.storageProfile.osDisk.osType))), ServerStatus = iff(type == 'microsoft.hybridcompute/machines', tostring(properties.status), tostring(properties.extended.instanceView.powerState.displayStatus))\n| where ServerStatus in ({WinExtServerStatus})\n| join kind=leftouter (\n    resources\n    | where type == 'microsoft.hybridcompute/machines/extensions' or type == 'microsoft.compute/virtualmachines/extensions'\n    | where properties.type in ('{WinExtension2:value}')\n    | extend VMId = toupper(substring(id, 0, indexof(id, '/extensions'))), ExtensionName = tostring(properties.type), Status = tostring(properties.provisioningState)\n) on $left.JoinID == $right.VMId\n| where OSType in ('windows')\n| extend Serverid = id, ProvisionState = pack(ExtensionName, Status)\n| summarize ExtProvision = make_bag(ProvisionState) by Serverid, OSType, ServerStatus\n| extend status = parse_json(ExtProvision)['{WinExtension2:value}']\n| project status\n| summarize count() by tostring(status)",
              "size": 3,
              "title": "{WinExtension2:value}",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{WinExtSubscriptions}"
              ],
              "visualization": "piechart",
              "chartSettings": {
                "seriesLabelSettings": [
                  {
                    "seriesName": "Succeeded",
                    "color": "green"
                  },
                  {
                    "seriesName": "",
                    "label": "Not Present",
                    "color": "gray"
                  },
                  {
                    "seriesName": "Failed",
                    "color": "red"
                  },
                  {
                    "seriesName": "Deleting",
                    "color": "redBright"
                  }
                ]
              }
            },
            "customWidth": "25",
            "name": "extwin-pie2"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type in ({WinExtMachineType})\n| extend JoinID = toupper(id), OSType = iff(type == 'microsoft.hybridcompute/machines', tostring(properties.osType), tolower(tostring(properties.storageProfile.osDisk.osType))), ServerStatus = iff(type == 'microsoft.hybridcompute/machines', tostring(properties.status), tostring(properties.extended.instanceView.powerState.displayStatus))\n| where ServerStatus in ({WinExtServerStatus})\n| join kind=leftouter (\n    resources\n    | where type == 'microsoft.hybridcompute/machines/extensions' or type == 'microsoft.compute/virtualmachines/extensions'\n    | where properties.type in ('{WinExtension3:value}')\n    | extend VMId = toupper(substring(id, 0, indexof(id, '/extensions'))), ExtensionName = tostring(properties.type), Status = tostring(properties.provisioningState)\n) on $left.JoinID == $right.VMId\n| where OSType in ('windows')\n| extend Serverid = id, ProvisionState = pack(ExtensionName, Status)\n| summarize ExtProvision = make_bag(ProvisionState) by Serverid, OSType, ServerStatus\n| extend status = parse_json(ExtProvision)['{WinExtension3:value}']\n| project status\n| summarize count() by tostring(status)",
              "size": 3,
              "title": "{WinExtension3:value}",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{WinExtSubscriptions}"
              ],
              "visualization": "piechart",
              "chartSettings": {
                "seriesLabelSettings": [
                  {
                    "seriesName": "Succeeded",
                    "color": "green"
                  },
                  {
                    "seriesName": "",
                    "label": "Not Present",
                    "color": "gray"
                  },
                  {
                    "seriesName": "Failed",
                    "color": "red"
                  },
                  {
                    "seriesName": "Deleting",
                    "color": "redBright"
                  }
                ]
              }
            },
            "customWidth": "25",
            "name": "extwin-pie3"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type in ({WinExtMachineType})\n| extend JoinID = toupper(id), OSType = iff(type == 'microsoft.hybridcompute/machines', tostring(properties.osType), tolower(tostring(properties.storageProfile.osDisk.osType))), ServerStatus = iff(type == 'microsoft.hybridcompute/machines', tostring(properties.status), tostring(properties.extended.instanceView.powerState.displayStatus))\n| where ServerStatus in ({WinExtServerStatus})\n| join kind=leftouter (\n    resources\n    | where type == 'microsoft.hybridcompute/machines/extensions' or type == 'microsoft.compute/virtualmachines/extensions'\n    | where properties.type in ('{WinExtension4:value}')\n    | extend VMId = toupper(substring(id, 0, indexof(id, '/extensions'))), ExtensionName = tostring(properties.type), Status = tostring(properties.provisioningState)\n) on $left.JoinID == $right.VMId\n| where OSType in ('windows')\n| extend Serverid = id, ProvisionState = pack(ExtensionName, Status)\n| summarize ExtProvision = make_bag(ProvisionState) by Serverid, OSType, ServerStatus\n| extend status = parse_json(ExtProvision)['{WinExtension4:value}']\n| project status\n| summarize count() by tostring(status)",
              "size": 3,
              "title": "{WinExtension4:value}",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{WinExtSubscriptions}"
              ],
              "visualization": "piechart",
              "chartSettings": {
                "seriesLabelSettings": [
                  {
                    "seriesName": "Succeeded",
                    "color": "green"
                  },
                  {
                    "seriesName": "",
                    "label": "Not Present",
                    "color": "gray"
                  },
                  {
                    "seriesName": "Failed",
