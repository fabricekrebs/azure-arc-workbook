    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 1,
            "content": {
              "json": "## Linux Arc Benefits\nTrack which Arc capabilities are configured across your Linux servers. Each tab shows configured vs. unconfigured servers for a specific capability."
            },
            "name": "linben-header"
          },
          {
            "type": 11,
            "content": {
              "version": "LinkItem/1.0",
              "style": "tabs",
              "links": [
                {
                  "id": "lb-overview",
                  "cellValue": "linBenTab",
                  "linkTarget": "parameter",
                  "linkLabel": "Overview",
                  "subTarget": "lbOverview",
                  "style": "link"
                },
                {
                  "id": "lb-update",
                  "cellValue": "linBenTab",
                  "linkTarget": "parameter",
                  "linkLabel": "Update Manager",
                  "subTarget": "lbUpdate",
                  "style": "link"
                },
                {
                  "id": "lb-defender",
                  "cellValue": "linBenTab",
                  "linkTarget": "parameter",
                  "linkLabel": "Defender",
                  "subTarget": "lbDefender",
                  "style": "link"
                },
                {
                  "id": "lb-guestconfig",
                  "cellValue": "linBenTab",
                  "linkTarget": "parameter",
                  "linkLabel": "Guest Config",
                  "subTarget": "lbGuestConfig",
                  "style": "link"
                },
                {
                  "id": "lb-monitoring",
                  "cellValue": "linBenTab",
                  "linkTarget": "parameter",
                  "linkLabel": "Monitoring",
                  "subTarget": "lbMonitoring",
                  "style": "link"
                },
                {
                  "id": "lb-tagging",
                  "cellValue": "linBenTab",
                  "linkTarget": "parameter",
                  "linkLabel": "Tagging",
                  "subTarget": "lbTagging",
                  "style": "link"
                },
                {
                  "id": "lb-ssh",
                  "cellValue": "linBenTab",
                  "linkTarget": "parameter",
                  "linkLabel": "Entra SSH",
                  "subTarget": "lbSsh",
                  "style": "link"
                }
              ]
            },
            "name": "linben-subtabs"
          },
          {
            "type": 12,
            "content": {
              "version": "NotebookGroup/1.0",
              "groupType": "editable",
              "items": [
                {
                  "type": 1,
                  "content": {
                    "json": "### Benefits Overview\nSummary of all Linux Arc capabilities across your estate."
                  }
                },
                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.osType == 'linux'\n| extend machineId = tolower(id)\n| join kind=leftouter (\n    resources\n    | where type == 'microsoft.hybridcompute/machines/extensions'\n    | extend parentId = tolower(substring(id, 0, indexof(id, '/extensions')))\n    | extend extType = tostring(properties.type)\n    | summarize extensions = make_set(extType) by parentId\n) on $left.machineId == $right.parentId\n| extend hasAMA = iff(isnotempty(extensions) and extensions has 'AzureMonitorLinuxAgent', 1, 0)\n| extend hasDefender = iff(isnotempty(extensions) and (extensions has 'MDE.Linux' or extensions has 'AzureSecurityLinuxAgent'), 1, 0)\n| extend hasGuestConfig = iff(isnotempty(extensions) and (extensions has 'ConfigurationForLinux' or extensions has 'AzurePolicyforLinux'), 1, 0)\n| extend hasSSH = iff(isnotempty(extensions) and extensions has 'AADSSHLoginForLinux', 1, 0)\n| extend hasTagging = iff(array_length(bag_keys(tags)) > 0, 1, 0)\n| extend hasUpdateMgr = iff(isnotnull(properties.osProfile.linuxConfiguration.patchSettings), 1, 0)\n| summarize\n    Total = count(),\n    ['Update Manager'] = sum(hasUpdateMgr),\n    ['Defender for Cloud'] = sum(hasDefender),\n    ['Monitoring (AMA)'] = sum(hasAMA),\n    ['Guest Configuration'] = sum(hasGuestConfig),\n    ['Entra SSH Login'] = sum(hasSSH),\n    ['Resource Tagging'] = sum(hasTagging)",
                    "size": 0,
                    "title": "Linux Arc Capabilities Summary",
                    "showExportToExcel": true,
                    "queryType": 1,
                    "resourceType": "microsoft.resourcegraph/resources",
                    "crossComponentResources": [
                      "{Subscriptions}"
                    ],
                    "gridSettings": {
                      "formatters": [
                        {
                          "columnMatch": "Total",
                          "formatter": 8,
                          "formatOptions": {
                            "palette": "blue"
                          }
                        },
                        {
                          "columnMatch": "Update Manager|Defender for Cloud|Monitoring|Guest Configuration|Entra SSH|Resource Tagging",
                          "formatter": 8,
                          "formatOptions": {
                            "palette": "green"
                          }
                        }
                      ],
                      "filter": true
                    }
                  },
                  "name": "linben-overview-grid"
                }
              ]
            },
            "conditionalVisibility": {
              "parameterName": "linBenTab",
              "comparison": "isEqualTo",
              "value": "lbOverview"
            },
            "name": "linben-overview-group"
          },
          {
            "type": 12,
            "content": {
              "version": "NotebookGroup/1.0",
              "groupType": "editable",
              "items": [
                {
                  "type": 1,
                  "content": {
                    "json": "### Update Manager\nLinux servers with patch assessment/management configured via Azure Update Manager."
                  }
                },
                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.osType == 'linux'\n| extend configured = isnotnull(properties.osProfile.linuxConfiguration.patchSettings)\n| summarize count() by Status = iff(configured, 'Configured', 'Not Configured')",
                    "size": 3,
                    "title": "Update Manager Status",
