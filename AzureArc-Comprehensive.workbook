            "name": "BpaCost",
            "label": "BPA ($/yr/server)",
            "type": 1,
            "value": "250"
          },
          {
            "id": "b3a82c40-0002-4a00-8000-000000000006",
            "version": "KqlParameterItem/1.0",
            "name": "HotpatchCost",
            "label": "Hotpatch ($/yr/server)",
            "type": 1,
            "value": "225"
          },
          {
            "id": "b3a82c40-0002-4a00-8000-000000000007",
            "version": "KqlParameterItem/1.0",
            "name": "MonitoringCost",
            "label": "Monitoring ($/yr/server)",
            "type": 1,
            "value": "200"
          },
          {
            "id": "b3a82c40-0002-4a00-8000-000000000008",
            "version": "KqlParameterItem/1.0",
            "name": "TaggingCost",
            "label": "Tagging ($/yr/server)",
            "type": 1,
            "value": "150"
          },
          {
            "id": "b3a82c40-0002-4a00-8000-000000000009",
            "version": "KqlParameterItem/1.0",
            "name": "WacCost",
            "label": "WAC ($/yr/server)",
            "type": 1,
            "value": "125"
          },
          {
            "id": "b3a82c40-0002-4a00-8000-00000000000a",
            "version": "KqlParameterItem/1.0",
            "name": "SqlDefenderCost",
            "label": "SQL Defender ($/yr)",
            "type": 1,
            "value": "25"
          },
          {
            "id": "b3a82c40-0002-4a00-8000-00000000000b",
