                    "version": "KqlItem/1.0",
                    "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.osType == 'linux'\n| extend tagCount = array_length(bag_keys(tags))\n| project Name = name, resourceGroup, osSku = tostring(properties.osSku), TagCount = tagCount, Tags = tostring(tags)\n| order by TagCount asc, Name asc",
                    "size": 0,
