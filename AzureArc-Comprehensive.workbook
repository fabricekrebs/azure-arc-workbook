    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 1,
            "content": {
              "json": "## Linux Extensions Monitor\nTrack extension deployment status across Arc-enabled Linux servers and Azure VMs. Select up to 4 extensions to compare."
            },
            "name": "extlinux-header"
          },
          {
            "type": 9,
            "content": {
              "version": "KqlParameterItem/1.0",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "parameters": [
                {
                  "id": "d3a82c40-0006-4a00-8000-000000000001",
                  "version": "KqlParameterItem/1.0",
                  "name": "LinExtSubscriptions",
                  "label": "Subscriptions",
                  "type": 6,
                  "multiSelect": true,
                  "quote": "'",
                  "delimiter": ",",
                  "typeSettings": {
                    "additionalResourceOptions": [
                      "value::all"
                    ],
                    "includeAll": true
                  },
                  "defaultValue": "value::all"
                },
                {
                  "id": "d3a82c40-0006-4a00-8000-000000000002",
                  "version": "KqlParameterItem/1.0",
                  "name": "LinExtMachineType",
                  "label": "Machine Type",
                  "type": 2,
                  "isRequired": true,
                  "multiSelect": true,
                  "quote": "'",
                  "delimiter": ",",
                  "value": [
                    "value::all"
                  ],
                  "typeSettings": {
                    "additionalResourceOptions": [
                      "value::all"
                    ],
                    "showDefault": false
                  },
                  "jsonData": "[\n  {\"value\": \"microsoft.hybridcompute/machines\", \"label\": \"Azure Arc Servers\"},\n  {\"value\": \"microsoft.compute/virtualmachines\", \"label\": \"Azure VMs\"}\n]",
                  "defaultValue": "value::all"
                },
                {
                  "id": "d3a82c40-0006-4a00-8000-000000000003",
                  "version": "KqlParameterItem/1.0",
                  "name": "LinExtServerStatus",
                  "label": "Server Status",
                  "type": 2,
                  "multiSelect": true,
                  "quote": "'",
                  "delimiter": ",",
                  "query": "resources\n| where type == 'microsoft.compute/virtualmachines' or type == 'microsoft.hybridcompute/machines'\n| extend ServerStatus = iff(type == 'microsoft.hybridcompute/machines', tostring(properties.status), tostring(properties.extended.instanceView.powerState.displayStatus))\n| distinct ServerStatus",
                  "crossComponentResources": [
                    "value::all"
                  ],
                  "typeSettings": {
                    "additionalResourceOptions": [
                      "value::all"
                    ],
                    "showDefault": false
                  },
                  "defaultValue": "value::all",
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources"
                }
              ],
              "style": "pills",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources"
            },
            "name": "extlinux-params"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines/extensions' or type == 'microsoft.compute/virtualmachines/extensions'\n| extend ExtensionName = tostring(properties.type)\n| distinct ExtensionName\n| where ExtensionName !contains 'Windows'",
              "size": 0,
              "queryType": 1,
