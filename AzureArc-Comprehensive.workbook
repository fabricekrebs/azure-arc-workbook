              "items": [
                {
                  "type": 1,
                  "content": {
                    "json": "### Microsoft Defender for Cloud\nLinux servers with Defender/MDE extension installed for threat detection."
                  }
                },
                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.osType == 'linux'\n| extend machineId = tolower(id)\n| join kind=leftouter (\n    resources\n    | where type == 'microsoft.hybridcompute/machines/extensions'\n    | where properties.type in ('MDE.Linux', 'AzureSecurityLinuxAgent')\n    | extend parentId = tolower(substring(id, 0, indexof(id, '/extensions')))\n    | distinct parentId\n    | extend hasDefender = true\n) on $left.machineId == $right.parentId\n| extend Status = iff(isnotnull(hasDefender), 'Configured', 'Not Configured')\n| summarize count() by Status",
                    "size": 3,
                    "title": "Defender Status",
