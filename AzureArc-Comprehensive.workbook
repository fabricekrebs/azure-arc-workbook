                          "representation": "success",
                          "text": "{0}"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "NotAssigned",
                          "representation": "warning",
                          "text": "{0}"
                        },
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "representation": "Blank",
                          "text": "{0}"
                        }
                      ]
                    }
                  }
                ],
                "rowLimit": 2000,
                "filter": true
              }
            },
            "name": "win-inventory-grid"
          }
        ]
      },
