                    "version": "KqlItem/1.0",
                    "query": "resources\n| where type == 'microsoft.azurearcdata/sqlserverinstances'\n| extend monitoringEnabled = tostring(properties.monitoring.enabled)\n| extend Performance = iff(monitoringEnabled == 'true', 'Configured', 'Not Configured')\n| project Name = name, resourceGroup, version = tostring(properties.version), edition = tostring(properties.edition), Performance\n| order by Performance desc, Name asc",
                    "size": 0,
                    "title": "SQL Instance Details",
                    "showExportToExcel": true,
