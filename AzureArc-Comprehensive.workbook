                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.osType == 'windows'\n| extend tagCount = array_length(bag_keys(tags))\n| extend Status = iff(tagCount > 0, 'Tagged', 'Not Tagged')\n| summarize count() by Status",
