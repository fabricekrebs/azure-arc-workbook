              "groupType": "editable",
              "items": [
                {
                  "type": 1,
                  "content": {
                    "json": "### Entra ID SSH Login\nLinux servers with AAD/Entra ID SSH login extension for identity-based access control."
                  }
                },
                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.osType == 'linux'\n| extend machineId = tolower(id)\n| join kind=leftouter (\n    resources\n    | where type == 'microsoft.hybridcompute/machines/extensions'\n    | where properties.type == 'AADSSHLoginForLinux'\n    | extend parentId = tolower(substring(id, 0, indexof(id, '/extensions')))\n    | distinct parentId\n    | extend hasSSH = true\n) on $left.machineId == $right.parentId\n| extend Status = iff(isnotnull(hasSSH), 'Configured', 'Not Configured')\n| summarize count() by Status",
                    "size": 3,
                    "title": "Entra SSH Login Status",
                    "queryType": 1,
                    "resourceType": "microsoft.resourcegraph/resources",
