    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 1,
            "content": {
              "json": "## Estate Overview\nHigh-level summary of all Arc-enabled servers and SQL Server instances across your subscriptions."
            },
            "name": "overview-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| summarize ServerCount = count()\n| extend Metric = 'All Arc Servers'",
              "size": 4,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "tiles",
              "tileSettings": {
                "titleContent": {
                  "columnMatch": "Metric",
                  "formatter": 1
                },
                "leftContent": {
                  "columnMatch": "ServerCount",
                  "formatter": 12,
                  "formatOptions": {
                    "palette": "auto"
                  },
                  "numberFormat": {
                    "unit": 0,
                    "options": {
                      "style": "decimal",
                      "maximumFractionDigits": 0
                    }
                  }
                },
                "showBorder": false
              }
            },
            "customWidth": "16",
            "name": "tile-all-servers"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.osType == 'windows'\n| summarize Count = count()\n| extend Metric = 'Windows Servers'",
              "size": 4,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "tiles",
              "tileSettings": {
                "titleContent": {
                  "columnMatch": "Metric",
                  "formatter": 1
                },
                "leftContent": {
                  "columnMatch": "Count",
                  "formatter": 12,
                  "formatOptions": {
                    "palette": "blue"
                  },
                  "numberFormat": {
                    "unit": 0,
                    "options": {
                      "style": "decimal"
                    }
                  }
                },
                "showBorder": false
              }
            },
            "customWidth": "16",
            "name": "tile-win-servers"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.osType == 'linux'\n| summarize Count = count()\n| extend Metric = 'Linux Servers'",
              "size": 4,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "tiles",
              "tileSettings": {
                "titleContent": {
                  "columnMatch": "Metric",
                  "formatter": 1
                },
                "leftContent": {
                  "columnMatch": "Count",
                  "formatter": 12,
                  "formatOptions": {
                    "palette": "orange"
                  },
                  "numberFormat": {
                    "unit": 0,
                    "options": {
                      "style": "decimal"
                    }
                  }
                },
                "showBorder": false
              }
            },
            "customWidth": "16",
            "name": "tile-linux-servers"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.mssqlDiscovered == 'true'\n| summarize Count = count()\n| extend Metric = 'SQL Server Hosts'",
              "size": 4,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "tiles",
              "tileSettings": {
                "titleContent": {
                  "columnMatch": "Metric",
                  "formatter": 1
                },
                "leftContent": {
                  "columnMatch": "Count",
                  "formatter": 12,
                  "formatOptions": {
                    "palette": "purple"
                  },
                  "numberFormat": {
                    "unit": 0,
                    "options": {
                      "style": "decimal"
                    }
                  }
                },
                "showBorder": false
              }
            },
            "customWidth": "16",
            "name": "tile-sql-hosts"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.azurearcdata/sqlserverinstances'\n| summarize Count = count()\n| extend Metric = 'SQL Instances'",
              "size": 4,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "tiles",
              "tileSettings": {
                "titleContent": {
                  "columnMatch": "Metric",
                  "formatter": 1
                },
                "leftContent": {
                  "columnMatch": "Count",
                  "formatter": 12,
                  "formatOptions": {
                    "palette": "purple"
                  },
                  "numberFormat": {
                    "unit": 0,
                    "options": {
                      "style": "decimal"
                    }
                  }
                },
                "showBorder": false
              }
            },
            "customWidth": "16",
            "name": "tile-sql-instances"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.azurearcdata/sqlserverinstances'\n| where properties.edition == 'Standard'\n| summarize Count = count()\n| extend Metric = 'SQL Standard'",
              "size": 4,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "tiles",
              "tileSettings": {
                "titleContent": {
                  "columnMatch": "Metric",
                  "formatter": 1
                },
                "leftContent": {
                  "columnMatch": "Count",
                  "formatter": 12,
                  "formatOptions": {
                    "palette": "green"
                  },
                  "numberFormat": {
                    "unit": 0,
                    "options": {
                      "style": "decimal"
                    }
                  }
                },
                "showBorder": false
              }
            },
            "customWidth": "16",
            "name": "tile-sql-standard"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.azurearcdata/sqlserverinstances'\n| where properties.edition == 'Enterprise'\n| summarize Count = count()\n| extend Metric = 'SQL Enterprise'",
              "size": 4,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "tiles",
              "tileSettings": {
                "titleContent": {
                  "columnMatch": "Metric",
                  "formatter": 1
                },
                "leftContent": {
                  "columnMatch": "Count",
                  "formatter": 12,
                  "formatOptions": {
                    "palette": "red"
                  },
                  "numberFormat": {
                    "unit": 0,
                    "options": {
                      "style": "decimal"
                    }
                  }
                },
                "showBorder": false
              }
            },
            "customWidth": "16",
            "name": "tile-sql-enterprise"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.osType == 'windows'\n| extend osSku = tostring(properties.osSku)\n| extend Version = case(\n    osSku contains '2012', 'Win Server 2012',\n    osSku contains '2016', 'Win Server 2016',\n    osSku contains '2019', 'Win Server 2019',\n    osSku contains '2022', 'Win Server 2022',\n    osSku contains '2025', 'Win Server 2025',\n    'Win Other')\n| summarize Count = count() by Version\n| order by Version asc",
              "size": 4,
              "title": "Windows Server Versions",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "tiles",
              "tileSettings": {
                "titleContent": {
                  "columnMatch": "Version",
                  "formatter": 1
                },
                "leftContent": {
                  "columnMatch": "Count",
                  "formatter": 12,
                  "formatOptions": {
                    "palette": "blue"
                  },
                  "numberFormat": {
                    "unit": 0,
                    "options": {
                      "style": "decimal",
                      "maximumFractionDigits": 0
                    }
                  }
                },
                "showBorder": false
              }
            },
            "customWidth": "50",
            "name": "tile-win-versions"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.azurearcdata/sqlserverinstances'\n| extend ver = tostring(properties.version)\n| extend Version = case(\n    ver contains '2012', 'SQL 2012',\n    ver contains '2014', 'SQL 2014',\n    ver contains '2016', 'SQL 2016',\n    ver contains '2017', 'SQL 2017',\n    ver contains '2019', 'SQL 2019',\n    ver contains '2022', 'SQL 2022',\n    ver contains '2025', 'SQL 2025',\n    'SQL Other')\n| summarize Count = count() by Version\n| order by Version asc",
              "size": 4,
              "title": "SQL Server Versions",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "tiles",
              "tileSettings": {
                "titleContent": {
                  "columnMatch": "Version",
                  "formatter": 1
                },
                "leftContent": {
                  "columnMatch": "Count",
                  "formatter": 12,
                  "formatOptions": {
                    "palette": "purple"
                  },
                  "numberFormat": {
                    "unit": 0,
                    "options": {
                      "style": "decimal",
                      "maximumFractionDigits": 0
                    }
                  }
                },
                "showBorder": false
              }
            },
            "customWidth": "50",
            "name": "tile-sql-versions"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| extend osType = tostring(properties.osType)\n| summarize ServerCount = count() by osType",
              "size": 3,
              "title": "OS Type Distribution",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "piechart"
            },
            "customWidth": "33",
            "name": "chart-os-type"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| extend osSku = tostring(properties.osSku)\n| extend osType = tostring(properties.osType)\n| where osType == 'windows'\n| extend shortOsSku = replace_string(osSku, 'Windows Server', '')\n| summarize ServerCount = count() by shortOsSku\n| order by shortOsSku asc",
              "size": 3,
              "title": "Windows Server by OS",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "barchart"
            },
            "customWidth": "33",
            "name": "chart-win-os"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.azurearcdata/sqlserverinstances'\n| extend SQLVersion = tostring(properties.version)\n| summarize Count = count() by SQLVersion\n| order by SQLVersion asc",
              "size": 3,
              "title": "SQL Instances by Version",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "barchart"
            },
            "customWidth": "33",
            "name": "chart-sql-version"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| extend osSku = tostring(properties.osSku)\n| extend osType = tostring(properties.osType)\n| where osType == 'linux'\n| summarize ServerCount = count() by osSku\n| order by osSku asc",
              "size": 3,
              "title": "Linux Servers by OS",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "barchart"
            },
            "customWidth": "50",
            "name": "chart-linux-os"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| extend osSku = tostring(properties.osSku)\n| extend mssqlDiscovered = properties.mssqlDiscovered\n| join kind=inner (\n    resourcecontainers\n    | where type == 'microsoft.resources/subscriptions'\n    | project subscriptionId, subscriptionName = name\n) on subscriptionId\n| extend SQLFound = iff(mssqlDiscovered == 'true', 1, 0)\n| summarize ServerCount = count(), SQLServerCount = sum(SQLFound) by subscriptionName, resourceGroup, osSku\n| order by subscriptionName asc, resourceGroup asc, osSku asc",
              "size": 0,
              "title": "Servers per Subscription & Resource Group",
              "showExportToExcel": true,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "gridSettings": {
                "rowLimit": 1000,
                "filter": true
              }
            },
            "customWidth": "50",
            "name": "grid-servers-per-sub"
          }
        ]
      },
      "conditionalVisibility": {
        "parameterName": "selectedTab",
        "comparison": "isEqualTo",
        "value": "overview"
      },
      "name": "tab-overview"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 1,
            "content": {
              "json": "## Windows Server Details\nDetailed inventory of all Arc-enabled Windows Servers including OS version, ESU status, hardware, and connectivity."
            },
            "name": "win-header"
          },
          {
            "type": 9,
            "content": {
              "version": "KqlParameterItem/1.0",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "parameters": [
                {
                  "id": "c3a82c40-0003-4a00-8000-000000000001",
                  "version": "KqlParameterItem/1.0",
                  "name": "WinServerStatus",
                  "label": "Server Status",
                  "type": 2,
                  "multiSelect": true,
                  "quote": "'",
                  "delimiter": ",",
                  "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.osType == 'windows'\n| extend ServerStatus = tostring(properties.status)\n| distinct ServerStatus",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "typeSettings": {
                    "additionalResourceOptions": [
                      "value::all"
                    ],
                    "showDefault": false
                  },
                  "defaultValue": "value::all",
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources"
                }
              ],
              "style": "pills",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources"
            },
            "name": "win-params"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.osType == 'windows'\n| extend ServerStatus = tostring(properties.status)\n| where ServerStatus in ({WinServerStatus})\n| extend coreCount = toint(properties.detectedProperties.coreCount)\n| extend osSku = tostring(properties.osSku)\n| summarize TotalCores = sum(coreCount) by osSku\n| order by TotalCores desc",
              "size": 3,
              "title": "Cores by Windows OS",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "piechart"
            },
            "customWidth": "33",
            "name": "win-cores-chart"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.osType == 'windows'\n| extend ServerStatus = tostring(properties.status)\n| where ServerStatus in ({WinServerStatus})\n| extend osSku = tostring(properties.osSku)\n| extend osVersion = tostring(properties.osVersion)\n| summarize ServerCount = count() by osSku, osVersion\n| order by osSku asc",
              "size": 0,
              "title": "OS Version by Windows OS SKU",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "gridSettings": {
                "rowLimit": 500,
                "filter": true
              }
            },
            "customWidth": "33",
            "name": "win-osversion-grid"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.osType == 'windows'\n| extend ServerStatus = tostring(properties.status)\n| where ServerStatus in ({WinServerStatus})\n| extend osSku = tostring(properties.osSku)\n| extend shortOsSku = replace_string(osSku, 'Windows Server', '')\n| summarize ServerCount = count() by shortOsSku, osVersion = tostring(properties.osVersion)\n| summarize osVersionCount = count() by shortOsSku\n| order by shortOsSku asc",
              "size": 3,
              "title": "Distinct OS Versions per SKU",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "barchart"
            },
            "customWidth": "33",
            "name": "win-versions-chart"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.osType == 'windows'\n| extend ServerStatus = tostring(properties.status)\n| where ServerStatus in ({WinServerStatus})\n| extend Cores = toint(properties.detectedProperties.logicalCoreCount)\n| extend TotalPhysicalMemory = toint(properties.detectedProperties.totalPhysicalMemoryInGigabytes)\n| extend osSku = tostring(properties.osSku)\n| extend osVersion = tostring(properties.osVersion)\n| extend ESU = tostring(properties.licenseProfile.esuProfile.licenseAssignmentState)\n| extend esuEligibility = tostring(properties.licenseProfile.esuProfile.esuEligibility)\n| extend agentVersion = tostring(properties.agentVersion)\n| extend Manufacturer = tostring(properties.detectedProperties.manufacturer)\n| extend Model = tostring(properties.detectedProperties.model)\n| extend Domain = tostring(properties.domainName)\n| extend FQDN = tostring(properties.machineFqdn)\n| extend LicenseType = tostring(properties.licenseProfile.licenseType)\n| extend SoftwareAssurance = tostring(properties.licenseProfile.softwareAssuranceCustomer)\n| join kind=leftouter (\n    resourcecontainers\n    | where type == 'microsoft.resources/subscriptions'\n    | project subscriptionId, subscriptionName = name\n) on subscriptionId\n| project Name = name, subscriptionName, resourceGroup, osSku, osVersion, ServerStatus, Cores, ['Memory (GB)'] = TotalPhysicalMemory, ESU, esuEligibility, agentVersion, Manufacturer, Model, Domain, FQDN, LicenseType, SoftwareAssurance, location\n| order by Name asc",
              "size": 0,
              "title": "Windows Server Inventory",
              "showAnalytics": true,
              "showExportToExcel": true,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "Name",
                    "formatter": 13,
                    "formatOptions": {
                      "linkTarget": "Resource",
                      "linkIsContextBlade": true,
                      "showIcon": true
                    }
                  },
                  {
                    "columnMatch": "ServerStatus",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "Connected",
                          "representation": "success",
                          "text": "{0}"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Disconnected",
                          "representation": "2",
                          "text": "{0}"
                        },
                        {
