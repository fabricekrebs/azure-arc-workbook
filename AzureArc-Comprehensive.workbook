            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type in ({LinExtMachineType})\n| extend JoinID = toupper(id),\n    OSName = iff(type == 'microsoft.hybridcompute/machines', tostring(properties.osProfile.computerName), tostring(properties.extended.instanceView.computerName)),\n    OSType = iff(type == 'microsoft.hybridcompute/machines', tostring(properties.osName), tolower(tostring(properties.storageProfile.osDisk.osType))),\n    OSsku = iff(type == 'microsoft.hybridcompute/machines', tostring(properties.osSku), tostring(properties.extended.instanceView.osName)),\n    ServerStatus = iff(type == 'microsoft.hybridcompute/machines', tostring(properties.status), tostring(properties.extended.instanceView.powerState.displayStatus))\n| where ServerStatus in ({LinExtServerStatus})\n| join kind=leftouter (\n    resources\n    | where type == 'microsoft.hybridcompute/machines/extensions' or type == 'microsoft.compute/virtualmachines/extensions'\n    | where properties.type in ('{LinExtension1:value}','{LinExtension2:value}','{LinExtension3:value}','{LinExtension4:value}')\n    | extend VMId = toupper(substring(id, 0, indexof(id, '/extensions'))),\n        ExtensionName = tostring(properties.type),\n        Version = iff(type == 'microsoft.hybridcompute/machines/extensions', tostring(properties.instanceView.typeHandlerVersion), tostring(properties.typeHandlerVersion)),\n        Status = tostring(properties.provisioningState)\n) on $left.JoinID == $right.VMId\n| where OSType contains 'linux' or OSsku contains 'Linux' or OSsku contains 'Ubuntu' or OSsku contains 'CentOS' or OSsku contains 'RHEL' or OSsku contains 'Debian' or OSsku contains 'SUSE'\n| extend ServerName = id, VersionNumber = pack(ExtensionName, Version), ProvisionState = pack(ExtensionName, Status)\n| summarize ExtVersions = make_bag(VersionNumber), ExtProvision = make_bag(ProvisionState) by ServerName, OSType, OSName, OSsku, ServerStatus\n| extend Extension1Version = tostring(parse_json(ExtVersions)['{LinExtension1:value}']),\n    ['1-{LinExtension1:value}'] = iff(isnotnull(parse_json(ExtProvision)['{LinExtension1:value}']), parse_json(ExtProvision)['{LinExtension1:value}'], ''),\n    Extension2Version = tostring(parse_json(ExtVersions)['{LinExtension2:value}']),\n    ['2-{LinExtension2:value}'] = iff(isnotnull(parse_json(ExtProvision)['{LinExtension2:value}']), parse_json(ExtProvision)['{LinExtension2:value}'], ''),\n    Extension3Version = tostring(parse_json(ExtVersions)['{LinExtension3:value}']),\n    ['3-{LinExtension3:value}'] = iff(isnotnull(parse_json(ExtProvision)['{LinExtension3:value}']), parse_json(ExtProvision)['{LinExtension3:value}'], ''),\n    Extension4Version = tostring(parse_json(ExtVersions)['{LinExtension4:value}']),\n    ['4-{LinExtension4:value}'] = iff(isnotnull(parse_json(ExtProvision)['{LinExtension4:value}']), parse_json(ExtProvision)['{LinExtension4:value}'], '')\n| project ServerName, OSsku, ServerStatus, OSType, ['1-{LinExtension1:value}'], Extension1Version, ['2-{LinExtension2:value}'], Extension2Version, ['3-{LinExtension3:value}'], Extension3Version, ['4-{LinExtension4:value}'], Extension4Version\n| sort by Extension1Version",
              "size": 2,
              "title": "Linux Extension Details",
              "showAnalytics": true,
              "showExportToExcel": true,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{LinExtSubscriptions}"
              ],
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "ServerName",
                    "formatter": 13,
                    "formatOptions": {
                      "linkTarget": "Resource",
                      "linkIsContextBlade": true,
                      "showIcon": true,
                      "customColumnWidthSetting": "27ch"
                    }
                  },
                  {
                    "columnMatch": "OSsku",
                    "formatter": 0,
                    "formatOptions": {
                      "customColumnWidthSetting": "35ch"
                    }
                  },
                  {
                    "columnMatch": "ServerStatus",
                    "formatter": 0,
                    "formatOptions": {
                      "customColumnWidthSetting": "14ch"
                    }
                  },
                  {
                    "columnMatch": "OSType",
                    "formatter": 0,
                    "formatOptions": {
                      "customColumnWidthSetting": "10ch"
                    }
                  },
                  {
                    "columnMatch": "^1-.",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "",
                          "text": ""
                        },
                        {
                          "operator": "!=",
                          "thresholdValue": "Succeeded",
                          "representation": "3",
                          "text": "[\"Extension1Version\"] ({0})"
                        },
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "representation": "success",
                          "text": "[\"Extension1Version\"]"
                        }
                      ],
                      "customColumnWidthSetting": "28ch"
                    }
                  },
                  {
                    "columnMatch": "Extension1Version",
                    "formatter": 5
                  },
                  {
                    "columnMatch": "^2-.",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "",
                          "text": ""
                        },
                        {
                          "operator": "!=",
                          "thresholdValue": "Succeeded",
                          "representation": "3",
                          "text": "[\"Extension2Version\"] ({0})"
                        },
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "representation": "success",
                          "text": "[\"Extension2Version\"]"
                        }
                      ],
                      "customColumnWidthSetting": "28ch"
                    }
                  },
                  {
                    "columnMatch": "Extension2Version",
                    "formatter": 5
                  },
                  {
                    "columnMatch": "^3-.",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "",
                          "text": ""
                        },
                        {
                          "operator": "!=",
                          "thresholdValue": "Succeeded",
                          "representation": "3",
                          "text": "[\"Extension3Version\"] ({0})"
                        },
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "representation": "success",
                          "text": "[\"Extension3Version\"]"
                        }
                      ],
                      "customColumnWidthSetting": "28ch"
                    }
                  },
                  {
                    "columnMatch": "Extension3Version",
                    "formatter": 5
                  },
                  {
                    "columnMatch": "^4-.",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "",
                          "text": ""
                        },
                        {
                          "operator": "!=",
                          "thresholdValue": "Succeeded",
                          "representation": "3",
                          "text": "[\"Extension4Version\"] ({0})"
                        },
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "representation": "success",
                          "text": "[\"Extension4Version\"]"
                        }
                      ],
                      "customColumnWidthSetting": "28ch"
                    }
                  },
                  {
                    "columnMatch": "Extension4Version",
                    "formatter": 5
                  }
                ],
                "rowLimit": 2000,
                "filter": true
              }
            },
            "name": "extlinux-detail-grid"
          }
        ]
      },
      "conditionalVisibility": {
        "parameterName": "selectedTab",
        "comparison": "isEqualTo",
        "value": "extlinux"
      },
      "name": "tab-extlinux"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 1,
            "content": {
              "json": "## ESU Assignment Tracker\nTrack Extended Security Updates registration for end-of-life and approaching-EOL Windows Server and SQL Server versions."
            },
            "name": "esu-header"
          },
          {
            "type": 1,
            "content": {
              "json": "### Windows Server 2012 — EOL: **10 Oct 2023** &nbsp; | &nbsp; Windows Server 2016 — EOL: **12 Jan 2027** &nbsp; | &nbsp; SQL Server 2012 — EOL: **12 Jul 2022** &nbsp; | &nbsp; SQL Server 2014 — EOL: **9 Jul 2024** &nbsp; | &nbsp; SQL Server 2016 — EOL: **14 Jul 2026**",
              "style": "warning"
            },
            "name": "esu-eol-dates"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type =~ 'microsoft.hybridcompute/machines'\n| extend osSku = tostring(properties.osSku)\n| extend ESU = tostring(properties.licenseProfile.esuProfile.licenseAssignmentState)\n| where osSku contains 'Windows Server 2012'\n| summarize ServerCount = count() by ESU",
              "size": 3,
              "title": "Windows 2012 ESU Status",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "piechart",
              "chartSettings": {
                "seriesLabelSettings": [
                  {
                    "seriesName": "Assigned",
                    "color": "green"
                  },
                  {
                    "seriesName": "NotAssigned",
                    "color": "redBright"
                  }
                ]
              }
            },
            "customWidth": "33",
            "name": "esu-win2012-pie"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| extend mssqlDiscovered = properties.mssqlDiscovered\n| where mssqlDiscovered == 'true'\n| extend machineId = tolower(tostring(id))\n| join kind=inner (\n    resources\n    | where type == 'microsoft.azurearcdata/sqlserverinstances'\n    | extend version = tostring(properties.version)\n    | extend edition = properties.edition\n    | extend containerId = tolower(tostring(properties.containerResourceId))\n    | where version contains '2012'\n    | where edition in ('Enterprise', 'Standard')\n    | where isnotempty(containerId)\n    | distinct containerId\n) on $left.machineId == $right.containerId\n| join kind=inner (\n    resources\n    | where type == 'microsoft.hybridcompute/machines/extensions'\n    | where properties.type in ('WindowsAgent.SqlServer', 'LinuxAgent.SqlServer')\n    | extend machineIdExt = tolower(iff(id contains '/extensions/WindowsAgent.SqlServer' or id contains '/extensions/LinuxAgent.SqlServer', substring(id, 0, indexof(id, '/extensions/')), ''))\n    | extend ESU = iff(isnotnull(properties.settings.enableExtendedSecurityUpdates), iff(properties.settings.enableExtendedSecurityUpdates == true, 'enabled', 'disabled'), 'N/A')\n    | project machineIdExt, ESU\n) on $left.machineId == $right.machineIdExt\n| summarize count() by ESU",
              "size": 3,
              "title": "SQL Server 2012 ESU Status",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "piechart",
              "chartSettings": {
                "seriesLabelSettings": [
                  {
                    "seriesName": "enabled",
                    "color": "green"
                  },
                  {
                    "seriesName": "disabled",
                    "color": "redBright"
                  },
                  {
                    "seriesName": "N/A",
                    "color": "gray"
                  }
                ]
              }
            },
            "customWidth": "33",
            "name": "esu-sql2012-pie"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.azurearcdata/sqlserverinstances'\n| where tostring(properties.version) contains '2014'\n| extend edition = tostring(properties.edition)\n| summarize Servers = count() by edition",
              "size": 3,
              "title": "SQL Server 2014 by Edition",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "piechart"
            },
            "customWidth": "33",
            "name": "esu-sql2014-pie"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| extend osSku = tostring(properties.osSku)\n| where osSku contains 'Windows Server 2012'\n| extend esuLicense = tostring(properties.licenseProfile.esuProfile.licenseAssignmentState)\n| where esuLicense == 'NotAssigned'\n| extend application = tostring(tags.Application)\n| summarize ServerCount = count() by application",
              "size": 3,
              "title": "Win 2012 ESU Not Assigned by Application",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "piechart"
            },
            "customWidth": "33",
            "name": "esu-win2012-app"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.osType == 'windows'\n| where tostring(properties.osSku) contains 'Windows Server 2012'\n| extend edition = iff(tostring(properties.osSku) contains 'Datacenter', 'Datacenter', 'Standard')\n| summarize serverCount = count() by edition",
              "size": 3,
              "title": "Win 2012 Standard vs Datacenter",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "piechart"
            },
            "customWidth": "33",
            "name": "esu-win2012-edition"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.azurearcdata/sqlserverinstances'\n| where tostring(properties.version) contains '2012'\n| extend edition = tostring(properties.edition)\n| summarize serverCount = count() by edition",
              "size": 3,
              "title": "SQL 2012 Editions",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "piechart"
            },
            "customWidth": "33",
            "name": "esu-sql2012-edition"
          },
          {
            "type": 1,
            "content": {
              "json": "---\n### Windows Server 2016 & SQL Server 2016 — Approaching End of Life",
              "style": "info"
            },
            "name": "esu-approaching-eol-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type =~ 'microsoft.hybridcompute/machines'\n| extend osSku = tostring(properties.osSku)\n| extend ESU = tostring(properties.licenseProfile.esuProfile.licenseAssignmentState)\n| where osSku contains 'Windows Server 2016'\n| summarize ServerCount = count() by ESU",
              "size": 3,
              "title": "Windows 2016 ESU Status",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "piechart",
              "chartSettings": {
                "seriesLabelSettings": [
                  {
                    "seriesName": "Assigned",
                    "color": "green"
                  },
                  {
                    "seriesName": "NotAssigned",
                    "color": "orange"
                  }
                ]
              }
            },
            "customWidth": "33",
            "name": "esu-win2016-pie"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.azurearcdata/sqlserverinstances'\n| where tostring(properties.version) contains '2016'\n| extend edition = tostring(properties.edition)\n| summarize Servers = count() by edition",
              "size": 3,
              "title": "SQL Server 2016 by Edition",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "piechart"
            },
            "customWidth": "33",
            "name": "esu-sql2016-pie"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.osType == 'windows'\n| where tostring(properties.osSku) contains 'Windows Server 2016'\n| extend edition = iff(tostring(properties.osSku) contains 'Datacenter', 'Datacenter', 'Standard')\n| summarize serverCount = count() by edition",
              "size": 3,
              "title": "Win 2016 Standard vs Datacenter",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "piechart"
            },
            "customWidth": "33",
            "name": "esu-win2016-edition"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type =~ 'microsoft.hybridcompute/machines'\n| extend osSku = tostring(properties.osSku)\n| where osSku contains 'Windows Server 2016'\n| extend esuLicense = tostring(properties.licenseProfile.esuProfile.licenseAssignmentState)\n| join kind=inner (\n    resourcecontainers\n    | where type == 'microsoft.resources/subscriptions'\n    | project subscriptionId, subscriptionName = name\n) on subscriptionId\n| project subscriptionName, resourceGroup, esuLicense\n| summarize ServerCount = count() by subscriptionName, resourceGroup, esuLicense",
              "size": 0,
              "title": "Win 2016 ESU by Subscription & Resource Group",
              "showExportToExcel": true,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "gridSettings": {
                "rowLimit": 1000,
                "filter": true
              }
            },
            "customWidth": "50",
            "name": "esu-win2016-grid"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.azurearcdata/sqlserverinstances'\n| where tostring(properties.version) contains '2016'\n| extend sqlEdition = tostring(properties.edition)\n| join kind=inner (\n    resourcecontainers\n    | where type == 'microsoft.resources/subscriptions'\n    | project subscriptionId, subscriptionName = name\n) on subscriptionId\n| project subscriptionName, resourceGroup, sqlEdition\n| summarize instanceCount = count() by subscriptionName, resourceGroup, sqlEdition",
              "size": 0,
              "title": "SQL 2016 by Subscription & Resource Group",
              "showExportToExcel": true,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "gridSettings": {
                "rowLimit": 1000,
                "filter": true
              }
            },
            "customWidth": "50",
            "name": "esu-sql2016-grid"
          },
          {
            "type": 1,
            "content": {
              "json": "---"
            },
            "name": "esu-separator"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type =~ 'microsoft.hybridcompute/machines'\n| extend esuEligibility = tostring(properties.licenseProfile.esuProfile.esuEligibility)\n| where esuEligibility == 'Eligible'\n| extend ESUAttached = iff(properties.licenseProfile.esuProfile.licenseAssignmentState == 'Assigned', 1, 0)\n| join kind=inner (\n    resourcecontainers\n    | where type == 'microsoft.resources/subscriptions'\n    | project subscriptionId, subscriptionName = name\n) on subscriptionId\n| summarize percentESUAssigned = toint(round(todouble(sum(ESUAttached)) / count() * 100, 2)) by subscriptionName",
              "size": 3,
              "title": "% Windows ESU Assigned by Subscription",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "barchart"
            },
            "name": "esu-pct-by-sub"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type =~ 'microsoft.hybridcompute/machines'\n| extend osSku = tostring(properties.osSku)\n| where osSku contains 'Windows Server 2012'\n| extend esuLicense = tostring(properties.licenseProfile.esuProfile.licenseAssignmentState)\n| join kind=inner (\n    resourcecontainers\n    | where type == 'microsoft.resources/subscriptions'\n    | project subscriptionId, subscriptionName = name\n) on subscriptionId\n| project subscriptionName, resourceGroup, esuLicense\n| summarize ServerCount = count() by subscriptionName, resourceGroup, esuLicense",
              "size": 0,
              "title": "Win 2012 ESU by Subscription & Resource Group",
              "showExportToExcel": true,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "gridSettings": {
                "rowLimit": 1000,
                "filter": true
              }
            },
            "customWidth": "50",
            "name": "esu-win2012-grid"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.azurearcdata/sqlserverinstances'\n| where tostring(properties.version) contains '2014'\n| extend sqlEdition = tostring(properties.edition)\n| join kind=inner (\n    resourcecontainers\n    | where type == 'microsoft.resources/subscriptions'\n    | project subscriptionId, subscriptionName = name\n) on subscriptionId\n| project subscriptionName, resourceGroup\n| summarize instanceCount = count() by subscriptionName, resourceGroup",
              "size": 0,
              "title": "SQL 2014 by Subscription & Resource Group",
              "showExportToExcel": true,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "gridSettings": {
                "rowLimit": 1000,
                "filter": true
              }
            },
            "customWidth": "50",
            "name": "esu-sql2014-grid"
          }
        ]
      },
      "conditionalVisibility": {
        "parameterName": "selectedTab",
        "comparison": "isEqualTo",
        "value": "esu"
      },
      "name": "tab-esu"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 1,
            "content": {
              "json": "## Windows Arc Benefits\nTrack which Arc capabilities are configured across your Windows servers. Each tab shows configured vs. unconfigured servers for a specific capability."
            },
            "name": "winben-header"
          },
          {
            "type": 11,
            "content": {
              "version": "LinkItem/1.0",
              "style": "tabs",
              "links": [
                {
                  "id": "wb-overview",
                  "cellValue": "winBenTab",
                  "linkTarget": "parameter",
                  "linkLabel": "Overview",
                  "subTarget": "wbOverview",
                  "style": "link"
                },
                {
                  "id": "wb-update",
                  "cellValue": "winBenTab",
                  "linkTarget": "parameter",
                  "linkLabel": "Update Manager",
                  "subTarget": "wbUpdate",
                  "style": "link"
                },
                {
                  "id": "wb-defender",
                  "cellValue": "winBenTab",
                  "linkTarget": "parameter",
                  "linkLabel": "Defender",
                  "subTarget": "wbDefender",
                  "style": "link"
                },
                {
                  "id": "wb-inventory",
                  "cellValue": "winBenTab",
                  "linkTarget": "parameter",
                  "linkLabel": "Inventory",
                  "subTarget": "wbInventory",
                  "style": "link"
                },
                {
                  "id": "wb-guestconfig",
                  "cellValue": "winBenTab",
                  "linkTarget": "parameter",
                  "linkLabel": "Guest Config",
                  "subTarget": "wbGuestConfig",
                  "style": "link"
                },
                {
                  "id": "wb-monitoring",
                  "cellValue": "winBenTab",
                  "linkTarget": "parameter",
                  "linkLabel": "Monitoring",
                  "subTarget": "wbMonitoring",
                  "style": "link"
                },
                {
                  "id": "wb-tagging",
                  "cellValue": "winBenTab",
                  "linkTarget": "parameter",
                  "linkLabel": "Tagging",
                  "subTarget": "wbTagging",
                  "style": "link"
                },
                {
                  "id": "wb-wac",
                  "cellValue": "winBenTab",
                  "linkTarget": "parameter",
                  "linkLabel": "WAC",
                  "subTarget": "wbWac",
                  "style": "link"
                },
                {
                  "id": "wb-hotpatch",
                  "cellValue": "winBenTab",
                  "linkTarget": "parameter",
                  "linkLabel": "Hotpatching",
                  "subTarget": "wbHotpatch",
                  "style": "link"
                },
                {
                  "id": "wb-changetrack",
                  "cellValue": "winBenTab",
                  "linkTarget": "parameter",
                  "linkLabel": "Change Tracking",
                  "subTarget": "wbChangeTrack",
                  "style": "link"
                },
                {
                  "id": "wb-keyvault",
                  "cellValue": "winBenTab",
                  "linkTarget": "parameter",
                  "linkLabel": "Key Vault",
                  "subTarget": "wbKeyVault",
                  "style": "link"
                },
                {
                  "id": "wb-hybridworker",
                  "cellValue": "winBenTab",
                  "linkTarget": "parameter",
                  "linkLabel": "Hybrid Workers",
                  "subTarget": "wbHybridWorker",
                  "style": "link"
                }
              ]
            },
            "name": "winben-subtabs"
          },
          {
            "type": 12,
            "content": {
              "version": "NotebookGroup/1.0",
              "groupType": "editable",
              "items": [
                {
                  "type": 1,
                  "content": {
                    "json": "### Benefits Overview\nSummary of all Windows Arc capabilities across your estate."
                  }
                },
                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.osType == 'windows'\n| extend machineId = tolower(id)\n| join kind=leftouter (\n    resources\n    | where type == 'microsoft.hybridcompute/machines/extensions'\n    | extend parentId = tolower(substring(id, 0, indexof(id, '/extensions')))\n    | extend extType = tostring(properties.type)\n    | summarize extensions = make_set(extType) by parentId\n) on $left.machineId == $right.parentId\n| extend hasAMA = iff(isnotempty(extensions) and extensions has 'AzureMonitorWindowsAgent', 1, 0)\n| extend hasDefender = iff(isnotempty(extensions) and (extensions has 'MDE.Windows' or extensions has 'AzureSecurityWindowsAgent'), 1, 0)\n| extend hasGuestConfig = iff(isnotempty(extensions) and (extensions has 'ConfigurationForWindows' or extensions has 'AzurePolicyforWindows'), 1, 0)\n| extend hasWAC = iff(isnotempty(extensions) and extensions has 'AdminCenter', 1, 0)\n| extend hasChangeTrack = iff(isnotempty(extensions) and extensions has 'ChangeTracking-Windows', 1, 0)\n| extend hasKeyVault = iff(isnotempty(extensions) and extensions has 'KeyVaultForWindows', 1, 0)\n| extend hasHybridWorker = iff(isnotempty(extensions) and extensions has 'HybridRunbookWorker', 1, 0)\n| extend hasTagging = iff(array_length(bag_keys(tags)) > 0, 1, 0)\n| extend hasUpdateMgr = iff(isnotnull(properties.osProfile.windowsConfiguration.patchSettings), 1, 0)\n| extend isWS2025 = iff(tostring(properties.osSku) contains '2025', 1, 0)\n| summarize\n    Total = count(),\n    ['Update Manager'] = sum(hasUpdateMgr),\n    ['Defender for Cloud'] = sum(hasDefender),\n    ['Monitoring (AMA)'] = sum(hasAMA),\n    ['Guest Configuration'] = sum(hasGuestConfig),\n    ['Windows Admin Center'] = sum(hasWAC),\n    ['Change Tracking'] = sum(hasChangeTrack),\n    ['Key Vault'] = sum(hasKeyVault),\n    ['Hybrid Workers'] = sum(hasHybridWorker),\n    ['Resource Tagging'] = sum(hasTagging),\n    ['Hotpatching (WS2025)'] = sum(isWS2025)",
                    "size": 0,
                    "title": "Windows Arc Capabilities Summary",
                    "showExportToExcel": true,
                    "queryType": 1,
                    "resourceType": "microsoft.resourcegraph/resources",
                    "crossComponentResources": [
                      "{Subscriptions}"
                    ],
                    "gridSettings": {
                      "formatters": [
                        {
                          "columnMatch": "Total",
                          "formatter": 8,
                          "formatOptions": {
                            "palette": "blue"
                          }
                        },
                        {
                          "columnMatch": "Update Manager|Defender for Cloud|Monitoring|Guest Configuration|Windows Admin Center|Resource Tagging|Hotpatching",
                          "formatter": 8,
                          "formatOptions": {
                            "palette": "green"
                          }
                        }
                      ],
                      "filter": true
                    }
                  },
                  "name": "winben-overview-grid"
                }
              ]
            },
            "conditionalVisibility": {
              "parameterName": "winBenTab",
              "comparison": "isEqualTo",
              "value": "wbOverview"
            },
            "name": "winben-overview-group"
          },
          {
            "type": 12,
            "content": {
              "version": "NotebookGroup/1.0",
              "groupType": "editable",
              "items": [
                {
                  "type": 1,
                  "content": {
                    "json": "### Update Manager\nServers with patch assessment/management configured via Azure Update Manager."
                  }
                },
                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.osType == 'windows'\n| extend configured = isnotnull(properties.osProfile.windowsConfiguration.patchSettings)\n| summarize count() by Status = iff(configured, 'Configured', 'Not Configured')",
                    "size": 3,
                    "title": "Update Manager Status",
                    "queryType": 1,
                    "resourceType": "microsoft.resourcegraph/resources",
                    "crossComponentResources": [
                      "{Subscriptions}"
                    ],
                    "visualization": "piechart",
                    "chartSettings": {
                      "seriesLabelSettings": [
                        {
                          "seriesName": "Configured",
                          "color": "green"
                        },
                        {
                          "seriesName": "Not Configured",
                          "color": "red"
                        }
                      ]
                    }
                  },
                  "customWidth": "40",
                  "name": "winben-update-pie"
                },
                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.osType == 'windows'\n| extend configured = isnotnull(properties.osProfile.windowsConfiguration.patchSettings)\n| extend osSku = tostring(properties.osSku)\n| project Name = name, resourceGroup, osSku, Status = tostring(properties.status), UpdateMgr = iff(configured, 'Configured', 'Not Configured')\n| order by UpdateMgr desc, Name asc",
                    "size": 0,
                    "title": "Server Details",
                    "showExportToExcel": true,
                    "queryType": 1,
                    "resourceType": "microsoft.resourcegraph/resources",
                    "crossComponentResources": [
                      "{Subscriptions}"
                    ],
                    "gridSettings": {
                      "formatters": [
                        {
                          "columnMatch": "Name",
                          "formatter": 13,
                          "formatOptions": {
                            "linkTarget": "Resource",
                            "showIcon": true
                          }
                        },
                        {
                          "columnMatch": "UpdateMgr",
                          "formatter": 18,
                          "formatOptions": {
                            "thresholdsOptions": "icons",
                            "thresholdsGrid": [
                              {
                                "operator": "==",
                                "thresholdValue": "Configured",
                                "representation": "success",
                                "text": "{0}"
                              },
                              {
                                "operator": "Default",
                                "thresholdValue": null,
                                "representation": "warning",
                                "text": "{0}"
                              }
                            ]
                          }
                        }
                      ],
                      "rowLimit": 2000,
                      "filter": true
                    }
                  },
                  "customWidth": "60",
                  "name": "winben-update-grid"
                },
                {
                  "type": 12,
                  "content": {
                    "version": "NotebookGroup/1.0",
                    "groupType": "editable",
                    "title": "Notes",
                    "expandable": true,
                    "expanded": false,
                    "items": [
                      {
                        "type": 1,
                        "content": {
                          "json": "**What it provides:** Automated patch assessment and deployment scheduling for Windows servers.\n\n**If not used:** Manual patching cycles, increased vulnerability window, labor-intensive compliance reporting.\n\n**Labor cost formula:** Hours per server per month x hourly rate x 12 months"
                        }
                      }
                    ]
                  },
                  "name": "winben-update-notes"
                }
              ]
            },
            "conditionalVisibility": {
              "parameterName": "winBenTab",
              "comparison": "isEqualTo",
              "value": "wbUpdate"
            },
            "name": "winben-update-group"
          },
          {
            "type": 12,
            "content": {
              "version": "NotebookGroup/1.0",
              "groupType": "editable",
              "items": [
                {
                  "type": 1,
                  "content": {
                    "json": "### Microsoft Defender for Cloud\nServers with Defender/MDE extension installed for threat detection."
                  }
                },
                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.osType == 'windows'\n| extend machineId = tolower(id)\n| join kind=leftouter (\n    resources\n    | where type == 'microsoft.hybridcompute/machines/extensions'\n    | where properties.type in ('MDE.Windows', 'AzureSecurityWindowsAgent')\n    | extend parentId = tolower(substring(id, 0, indexof(id, '/extensions')))\n    | distinct parentId\n    | extend hasDefender = true\n) on $left.machineId == $right.parentId\n| extend Status = iff(isnotnull(hasDefender), 'Configured', 'Not Configured')\n| summarize count() by Status",
                    "size": 3,
                    "title": "Defender Status",
