              "items": [
                {
                  "type": 1,
                  "content": {
                    "json": "### Resource Tagging\nLinux servers with resource tags applied for cost tracking and organization."
                  }
                },
                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.osType == 'linux'\n| extend tagCount = array_length(bag_keys(tags))\n| extend Status = iff(tagCount > 0, 'Tagged', 'Not Tagged')\n| summarize count() by Status",
                    "size": 3,
                    "title": "Tagging Status",
                    "queryType": 1,
                    "resourceType": "microsoft.resourcegraph/resources",
