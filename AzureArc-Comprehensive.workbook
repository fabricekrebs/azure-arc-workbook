            "name": "SqlInventoryCost",
            "label": "SQL Inventory ($/qtr)",
            "type": 1,
            "value": "40"
          }
        ],
        "style": "formHorizontal",
        "queryType": 0,
        "resourceType": "microsoft.operationalinsights/workspaces"
      },
      "conditionalVisibility": {
        "parameterName": "ShowCostAnalysis",
