        "value": "sqlservers"
      },
      "name": "tab-sqlservers"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 1,
            "content": {
              "json": "## SQL Best Practices Assessment\nAnalyze SQL Server assessment results from Log Analytics. Requires a Log Analytics workspace with **SqlAssessment_CL** data."
            },
            "name": "sqlbpa-header"
          },
          {
            "type": 9,
            "content": {
              "version": "KqlParameterItem/1.0",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "parameters": [
                {
                  "id": "e3a82c40-0010-4a00-8000-000000000001",
                  "version": "KqlParameterItem/1.0",
                  "name": "BpaSubscription",
                  "label": "Subscription",
                  "type": 6,
                  "isRequired": true,
                  "multiSelect": true,
                  "quote": "'",
                  "delimiter": ",",
                  "typeSettings": {
                    "additionalResourceOptions": [
                      "value::all"
                    ],
                    "includeAll": true,
                    "showDefault": false
                  },
                  "defaultValue": "value::all"
                },
                {
                  "id": "e3a82c40-0010-4a00-8000-000000000002",
                  "version": "KqlParameterItem/1.0",
                  "name": "LogAnalyticsWorkspace",
                  "label": "Log Analytics Workspace",
                  "type": 5,
                  "query": "where type =~ 'microsoft.operationalinsights/workspaces'\n| project id",
                  "crossComponentResources": [
                    "{BpaSubscription}"
                  ],
                  "typeSettings": {
                    "additionalResourceOptions": []
                  },
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources"
                },
                {
                  "id": "e3a82c40-0010-4a00-8000-000000000003",
                  "version": "KqlParameterItem/1.0",
                  "name": "BpaServerName",
                  "label": "Server Name",
                  "type": 2,
                  "multiSelect": true,
                  "quote": "'",
                  "delimiter": ",",
                  "query": "SqlAssessment_CL\n| extend asmt = parse_csv(RawData)\n| extend TargetType = case(asmt[6] == 1, 'Server', asmt[6] == 2, 'Database', '')\n| where TargetType == 'Server'\n| extend ServerName = replace_string(tostring(asmt[7]), '\\\\', '#')\n| distinct ServerName",
                  "crossComponentResources": [
                    "{LogAnalyticsWorkspace}"
                  ],
                  "typeSettings": {
                    "additionalResourceOptions": [
                      "value::all"
                    ],
                    "showDefault": false
                  },
                  "defaultValue": "value::all",
                  "queryType": 0,
                  "resourceType": "microsoft.operationalinsights/workspaces"
                },
                {
                  "id": "e3a82c40-0010-4a00-8000-000000000004",
                  "version": "KqlParameterItem/1.0",
                  "name": "BpaTimeRange",
                  "label": "Time Range",
                  "type": 4,
                  "isRequired": true,
                  "typeSettings": {
                    "selectableValues": [
                      {
                        "durationMs": 86400000
                      },
                      {
                        "durationMs": 604800000
                      },
                      {
                        "durationMs": 2592000000
                      },
                      {
                        "durationMs": 7776000000
                      }
                    ]
                  },
                  "value": {
                    "durationMs": 2592000000
                  }
                }
              ],
              "style": "pills",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces"
            },
            "name": "sqlbpa-params"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "SqlAssessment_CL\n| extend asmt = parse_csv(RawData)\n| extend AsmtId = tostring(asmt[1]), CheckId = tostring(asmt[2]), TargetType = case(asmt[6] == 1, 'Server', asmt[6] == 2, 'Database', ''), TargetName = tostring(asmt[7]), Sev = toint(asmt[8])\n| join kind=inner (\n    SqlAssessment_CL\n    | extend asmt = parse_csv(RawData)\n    | extend AsmtId = tostring(asmt[1])\n    | summarize arg_max(TimeGenerated, *) by _ResourceId\n    | project AsmtId\n) on AsmtId\n| where Sev >= 0 and TargetType == 'Server'\n| extend ServerName = replace_string(tostring(asmt[7]), '\\\\', '#')\n| where ServerName in (dynamic([{BpaServerName}]))\n| summarize count() by TargetName",
              "size": 3,
              "title": "Issues by Server",
              "timeContextFromParameter": "BpaTimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "crossComponentResources": [
                "{LogAnalyticsWorkspace}"
              ],
              "visualization": "piechart"
            },
            "customWidth": "33",
            "name": "sqlbpa-by-server"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "SqlAssessment_CL\n| extend asmt = parse_csv(RawData)\n| extend AsmtId = tostring(asmt[1]), CheckId = tostring(asmt[2]), TargetType = case(asmt[6] == 1, 'Server', asmt[6] == 2, 'Database', ''), TargetName = tostring(asmt[7]), Sev = toint(asmt[8])\n| join kind=inner (\n    SqlAssessment_CL\n    | extend asmt = parse_csv(RawData)\n    | extend AsmtId = tostring(asmt[1])\n    | summarize arg_max(TimeGenerated, *) by _ResourceId\n    | project AsmtId\n) on AsmtId\n| where Sev >= 0 and TargetType == 'Database'\n| extend ServerName = tostring(split(tostring(asmt[7]), ':')[0])\n| extend ServerNameFilter = replace_string(ServerName, '\\\\', '#')\n| where ServerNameFilter in (dynamic([{BpaServerName}]))\n| summarize count() by TargetName",
              "size": 3,
              "title": "Issues by Database",
              "timeContextFromParameter": "BpaTimeRange",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "crossComponentResources": [
                "{LogAnalyticsWorkspace}"
              ],
              "visualization": "piechart"
            },
            "customWidth": "33",
            "name": "sqlbpa-by-database"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "SqlAssessment_CL\n| extend asmt = parse_csv(RawData)\n| extend AsmtId = tostring(asmt[1]), CheckId = tostring(asmt[2]), TargetType = case(asmt[6] == 1, 'Server', asmt[6] == 2, 'Database', ''), TargetName = tostring(asmt[7]),\n    Severity = case(asmt[8] == 30, 'High', asmt[8] == 20, 'Medium', asmt[8] == 10, 'Low', asmt[8] == 0, 'Information', 'Passed'),\n    Sev = toint(asmt[8])\n| join kind=inner (\n    SqlAssessment_CL\n    | extend asmt = parse_csv(RawData)\n    | extend AsmtId = tostring(asmt[1])\n    | summarize arg_max(TimeGenerated, *) by _ResourceId\n    | project AsmtId\n) on AsmtId\n| where Sev >= 0\n| extend ServerName = case(TargetType == 'Server', tostring(asmt[7]), tostring(split(tostring(asmt[7]), ':')[0]))\n| extend ServerNameFilter = replace_string(ServerName, '\\\\', '#')\n| where ServerNameFilter in (dynamic([{BpaServerName}]))\n| summarize count() by Severity, Sev\n| order by Sev",
              "size": 3,
              "title": "Issues by Severity",
              "timeContextFromParameter": "BpaTimeRange",
              "exportFieldName": "Severity",
              "exportParameterName": "bpaSeverity",
              "exportDefaultValue": "",
              "showExportToExcel": true,
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "crossComponentResources": [
                "{LogAnalyticsWorkspace}"
              ],
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "Severity",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "High",
                          "representation": "Sev0",
                          "text": "{0}"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Medium",
                          "representation": "Sev1",
                          "text": "{0}"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Low",
                          "representation": "Sev2",
                          "text": "{0}"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Information",
                          "representation": "Sev3",
                          "text": "{0}"
                        },
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "representation": "success",
                          "text": "{0}"
                        }
                      ]
                    }
                  },
                  {
                    "columnMatch": "Sev",
                    "formatter": 5
                  }
                ]
              }
            },
            "customWidth": "33",
            "name": "sqlbpa-by-severity"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "SqlAssessment_CL\n| extend asmt = parse_csv(RawData)\n| extend AsmtId = tostring(asmt[1]), CheckId = tostring(asmt[2]), DisplayString = tostring(asmt[3]), Description = tostring(asmt[4]), HelpLink = tostring(asmt[5]),\n    TargetType = case(asmt[6] == 1, 'Server', asmt[6] == 2, 'Database', ''),\n    TargetName = tostring(asmt[7]),\n    Severity = case(asmt[8] == 30, 'High', asmt[8] == 20, 'Medium', asmt[8] == 10, 'Low', asmt[8] == 0, 'Information', asmt[8] == 1, 'Warning', asmt[8] == 2, 'Critical', 'Passed'),\n    Message = tostring(asmt[9]), Sev = toint(asmt[8])\n| join kind=inner (\n    SqlAssessment_CL\n    | extend asmt = parse_csv(RawData)\n    | extend AsmtId = tostring(asmt[1])\n    | summarize arg_max(TimeGenerated, *) by _ResourceId\n    | project AsmtId\n) on AsmtId\n| where Sev >= 0\n| extend ServerName = case(TargetType == 'Server', tostring(asmt[7]), tostring(split(tostring(asmt[7]), ':')[0]))\n| extend ServerNameFilter = replace_string(ServerName, '\\\\', '#')\n| where ServerNameFilter in (dynamic([{BpaServerName}]))\n| where '{bpaSeverity}' == '' or Severity == '{bpaSeverity}'\n| order by Sev desc, CheckId\n| project TimeGenerated, TargetType, ArcServer = _ResourceId, Severity, CheckId, DisplayString, Description, TargetName",
              "size": 0,
              "title": "Assessment Details{bpaSeverity:+ — filtered: {bpaSeverity}}",
              "timeContextFromParameter": "BpaTimeRange",
              "showExportToExcel": true,
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "crossComponentResources": [
                "{LogAnalyticsWorkspace}"
              ],
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "TimeGenerated",
                    "formatter": 0,
                    "formatOptions": {
                      "customColumnWidthSetting": "22ch"
                    }
                  },
                  {
                    "columnMatch": "TargetType",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "Server",
                          "representation": "resource",
                          "text": "{0}"
                        },
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "representation": "ResourceFlat",
                          "text": "{0}"
                        }
                      ],
                      "customColumnWidthSetting": "14ch"
                    }
                  },
                  {
                    "columnMatch": "Severity",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "High",
                          "representation": "Sev0",
                          "text": "{0}"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Medium",
                          "representation": "Sev1",
                          "text": "{0}"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Low",
                          "representation": "Sev2",
                          "text": "{0}"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Information",
                          "representation": "Sev3",
                          "text": "{0}"
                        },
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "representation": "success",
                          "text": "{0}"
                        }
                      ],
                      "customColumnWidthSetting": "14ch"
                    }
                  },
                  {
                    "columnMatch": "CheckId",
                    "formatter": 0,
                    "formatOptions": {
                      "customColumnWidthSetting": "16ch"
                    }
                  },
                  {
                    "columnMatch": "Description",
                    "formatter": 0,
                    "formatOptions": {
                      "customColumnWidthSetting": "80ch"
                    }
                  }
                ],
                "rowLimit": 500,
                "filter": true
              }
            },
            "name": "sqlbpa-detail-grid"
          }
        ]
      },
      "conditionalVisibility": {
        "parameterName": "selectedTab",
        "comparison": "isEqualTo",
        "value": "sqlbpa"
      },
      "name": "tab-sqlbpa"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 1,
            "content": {
              "json": "## Tag Distribution\nServer distribution by common tag values. Edit tag names in queries to match your organization's tagging convention."
            },
            "name": "tags-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| extend application = tostring(tags.Application)\n| summarize ServerCount = count() by application\n| order by application asc",
              "size": 3,
              "title": "All Servers by Application Tag",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "barchart"
            },
            "name": "tags-app"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| extend dataCenter = tostring(tags.DataCenter)\n| summarize ServerCount = count() by dataCenter\n| order by dataCenter asc",
              "size": 3,
              "title": "All Servers by DataCenter Tag",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "barchart"
            },
            "customWidth": "50",
            "name": "tags-dc"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| extend businessUnit = tostring(tags.BusinessUnit)\n| summarize ServerCount = count() by businessUnit\n| order by businessUnit asc",
              "size": 3,
              "title": "All Servers by Business Unit Tag",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "barchart"
            },
            "customWidth": "50",
            "name": "tags-bu"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| extend location_tag = tostring(tags.Location)\n| summarize ServerCount = count() by location_tag\n| order by location_tag asc",
              "size": 3,
              "title": "All Servers by Location Tag",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "barchart"
            },
            "customWidth": "50",
            "name": "tags-loc"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| extend environment = tostring(tags.Environment)\n| summarize ServerCount = count() by environment\n| order by environment asc",
              "size": 3,
              "title": "All Servers by Environment Tag",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "barchart"
            },
            "customWidth": "50",
            "name": "tags-env"
          },
          {
            "type": 1,
            "content": {
              "json": "---\n### SQL Server Tag Distribution"
            },
            "name": "tags-sql-divider"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.mssqlDiscovered == 'true'\n| extend application = tostring(tags.Application)\n| summarize ServerCount = count() by application\n| order by application asc",
              "size": 3,
              "title": "SQL Server Hosts by Application",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "barchart"
            },
            "customWidth": "50",
            "name": "tags-sql-app"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.mssqlDiscovered == 'true'\n| extend location_tag = tostring(tags.Location)\n| summarize ServerCount = count() by location_tag\n| order by location_tag asc",
              "size": 3,
              "title": "SQL Server Hosts by Location",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "barchart"
            },
            "customWidth": "50",
            "name": "tags-sql-loc"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.mssqlDiscovered == 'true'\n| extend businessUnit = tostring(tags.BusinessUnit)\n| summarize ServerCount = count() by businessUnit\n| order by businessUnit asc",
              "size": 3,
              "title": "SQL Server Hosts by Business Unit",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "barchart"
            },
            "customWidth": "50",
            "name": "tags-sql-bu"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.mssqlDiscovered == 'true'\n| extend dataCenter = tostring(tags.DataCenter)\n| summarize ServerCount = count() by dataCenter\n| order by dataCenter asc",
              "size": 3,
              "title": "SQL Server Hosts by DataCenter",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "barchart"
            },
            "customWidth": "50",
            "name": "tags-sql-dc"
          }
        ]
      },
      "conditionalVisibility": {
        "parameterName": "selectedTab",
        "comparison": "isEqualTo",
        "value": "tags"
      },
      "name": "tab-tags"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 1,
            "content": {
              "json": "## Log Analytics Gap Analysis\nIdentify machines reporting to Log Analytics that are **not yet onboarded** to Azure Arc or are not Azure VMs. This helps discover servers that should be Arc-enabled."
            },
            "name": "la-header"
          },
          {
            "type": 9,
            "content": {
              "version": "KqlParameterItem/1.0",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "parameters": [
                {
                  "id": "f3a82c40-0012-4a00-8000-000000000001",
                  "version": "KqlParameterItem/1.0",
                  "name": "LaSubscriptions",
                  "label": "Subscriptions",
                  "type": 6,
                  "multiSelect": true,
                  "quote": "'",
                  "delimiter": ",",
                  "typeSettings": {
                    "additionalResourceOptions": [
                      "value::all"
                    ],
                    "includeAll": true
                  },
                  "defaultValue": "value::all"
                },
                {
                  "id": "f3a82c40-0012-4a00-8000-000000000002",
                  "version": "KqlParameterItem/1.0",
                  "name": "LaWorkspaces",
                  "label": "Workspaces",
                  "type": 5,
                  "multiSelect": true,
                  "quote": "'",
                  "delimiter": ",",
                  "query": "where type =~ 'microsoft.operationalinsights/workspaces'\n| project id",
                  "crossComponentResources": [
                    "{LaSubscriptions}"
                  ],
                  "typeSettings": {
                    "additionalResourceOptions": [
                      "value::all"
                    ],
                    "showDefault": false
                  },
                  "defaultValue": "value::all",
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources"
                },
                {
                  "id": "f3a82c40-0012-4a00-8000-000000000003",
                  "version": "KqlParameterItem/1.0",
                  "name": "ShowOriginalTables",
                  "label": "Show Original Tables",
                  "type": 10,
                  "value": "No",
                  "typeSettings": {
                    "additionalResourceOptions": [],
                    "showDefault": false
                  },
                  "jsonData": "[\"Yes\", \"No\"]"
                }
              ],
              "style": "pills",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces"
            },
            "name": "la-params"
          },
          {
            "type": 1,
            "content": {
              "json": "The result shows machines reporting via Heartbeat in Log Analytics that **are NOT** Azure VMs nor Azure Arc machines — potential candidates for Arc onboarding.",
              "style": "info"
            },
            "name": "la-info"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "Heartbeat\n| summarize arg_max(TimeGenerated,*) by Resource\n| project ResourceId, Resource, Category, ComputerIP, SCAgentChannel\n| count\n| extend Metric = 'Log Analytics entries'",
              "size": 4,
              "timeContext": {
                "durationMs": 86400000
              },
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "crossComponentResources": [
                "{LaWorkspaces}"
              ],
              "visualization": "tiles",
              "tileSettings": {
                "titleContent": {
                  "columnMatch": "Metric",
                  "formatter": 1
                },
                "leftContent": {
                  "columnMatch": "Count",
                  "formatter": 12,
                  "formatOptions": {
                    "palette": "auto"
                  },
                  "numberFormat": {
                    "unit": 0,
                    "options": {
                      "style": "decimal",
                      "maximumFractionDigits": 0
                    }
                  }
                },
                "showBorder": false
              }
            },
            "customWidth": "50",
            "name": "la-tile-heartbeat"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines' or type == 'microsoft.compute/virtualmachines'\n| count\n| extend Metric = 'Arc & Azure VM entries'",
              "size": 4,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{LaSubscriptions}"
              ],
              "visualization": "tiles",
              "tileSettings": {
                "titleContent": {
                  "columnMatch": "Metric",
                  "formatter": 1
                },
                "leftContent": {
                  "columnMatch": "Count",
                  "formatter": 12,
                  "formatOptions": {
                    "palette": "auto"
                  },
                  "numberFormat": {
                    "unit": 0,
                    "options": {
                      "style": "decimal"
                    }
                  }
                },
                "showBorder": false
              }
            },
            "customWidth": "50",
            "name": "la-tile-arg"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "Heartbeat\n| summarize arg_max(TimeGenerated,*) by Resource\n| project ResourceId, Resource, Category, ComputerIP, SCAgentChannel, TimeGenerated\n| sort by Resource asc",
              "size": 0,
              "title": "Log Analytics — Heartbeat Entries",
              "timeContext": {
                "durationMs": 86400000
              },
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "crossComponentResources": [
                "{LaWorkspaces}"
              ],
              "gridSettings": {
                "rowLimit": 10000,
                "filter": true
              }
            },
            "conditionalVisibility": {
              "parameterName": "ShowOriginalTables",
              "comparison": "isEqualTo",
              "value": "Yes"
            },
            "name": "la-heartbeat-grid"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines' or type == 'microsoft.compute/virtualmachines'\n| project id, name",
              "size": 0,
              "title": "Resource Graph — Arc & Azure VMs",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "value::all"
              ],
              "gridSettings": {
                "rowLimit": 10000,
                "filter": true
              }
            },
            "conditionalVisibility": {
              "parameterName": "ShowOriginalTables",
              "comparison": "isEqualTo",
              "value": "Yes"
            },
            "name": "la-arg-grid"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "{\"version\":\"Merge/1.0\",\"merges\":[{\"id\":\"ffbd6be0-0895-45b7-81a1-99b7222b60bd\",\"mergeType\":\"leftanti\",\"leftTable\":\"la-heartbeat-grid\",\"rightTable\":\"la-arg-grid\",\"leftColumn\":\"Resource\",\"rightColumn\":\"name\"}],\"projectRename\":[{\"originalName\":\"[la-heartbeat-grid].ResourceId\",\"mergedName\":\"ResourceId\",\"fromId\":\"ffbd6be0-0895-45b7-81a1-99b7222b60bd\"},{\"originalName\":\"[la-heartbeat-grid].Resource\",\"mergedName\":\"Resource Name\",\"fromId\":\"ffbd6be0-0895-45b7-81a1-99b7222b60bd\"},{\"originalName\":\"[la-heartbeat-grid].Category\",\"mergedName\":\"Category\",\"fromId\":\"ffbd6be0-0895-45b7-81a1-99b7222b60bd\"},{\"originalName\":\"[la-heartbeat-grid].ComputerIP\",\"mergedName\":\"ComputerIP\",\"fromId\":\"ffbd6be0-0895-45b7-81a1-99b7222b60bd\"},{\"originalName\":\"[la-heartbeat-grid].SCAgentChannel\",\"mergedName\":\"SCAgentChannel\",\"fromId\":\"ffbd6be0-0895-45b7-81a1-99b7222b60bd\"},{\"originalName\":\"[la-heartbeat-grid].TimeGenerated\",\"mergedName\":\"TimeGenerated\",\"fromId\":\"ffbd6be0-0895-45b7-81a1-99b7222b60bd\"}]}",
              "size": 0,
              "title": "Machines in Log Analytics but NOT in Arc nor Azure VMs",
              "showExportToExcel": true,
              "queryType": 7,
              "gridSettings": {
                "sortBy": [
                  {
                    "itemKey": "TimeGenerated",
                    "sortOrder": 2
                  }
                ],
                "filter": true
              },
              "sortBy": [
                {
                  "itemKey": "TimeGenerated",
                  "sortOrder": 2
                }
              ]
            },
            "name": "la-gap-grid"
          }
        ]
      },
      "conditionalVisibility": {
        "parameterName": "selectedTab",
        "comparison": "isEqualTo",
        "value": "loganalytics"
      },
      "name": "tab-loganalytics"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 1,
            "content": {
              "json": "## Agent Health & Operational Insights\nMonitor Arc agent versions, connectivity health, service status, cloud provider distribution, and license compliance across your estate."
            },
            "name": "health-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| extend agentVersion = tostring(properties.agentVersion)\n| summarize ServerCount = count() by agentVersion\n| order by agentVersion asc",
              "size": 3,
              "title": "Agent Version Distribution",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "barchart"
            },
            "name": "health-agent-version"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| extend cloudProvider = coalesce(tostring(properties.cloudMetadata.provider), 'On-Premises / Unknown')\n| summarize ServerCount = count() by cloudProvider",
              "size": 3,
              "title": "Cloud Provider Distribution",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "piechart"
            },
            "customWidth": "33",
            "name": "health-cloud-provider"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| extend status = tostring(properties.status)\n| summarize ServerCount = count() by status",
              "size": 3,
              "title": "Connection Status (All Servers)",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "piechart",
              "chartSettings": {
                "seriesLabelSettings": [
                  {
                    "seriesName": "Connected",
                    "color": "green"
                  },
                  {
                    "seriesName": "Disconnected",
                    "color": "red"
                  },
                  {
                    "seriesName": "Expired",
                    "color": "gray"
                  }
                ]
              }
            },
            "customWidth": "33",
            "name": "health-connection-status"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| extend licenseType = coalesce(tostring(properties.licenseProfile.licenseType), 'Not Set')\n| summarize ServerCount = count() by licenseType",
              "size": 3,
              "title": "License Type Distribution",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "visualization": "piechart"
            },
            "customWidth": "33",
            "name": "health-license-type"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| where properties.status == 'Disconnected'\n| extend lastStatusChange = tostring(properties.lastStatusChange)\n| extend osType = tostring(properties.osType)\n| extend osSku = tostring(properties.osSku)\n| extend agentVersion = tostring(properties.agentVersion)\n| join kind=leftouter (\n    resourcecontainers\n    | where type == 'microsoft.resources/subscriptions'\n    | project subscriptionId, subscriptionName = name\n) on subscriptionId\n| project Name = name, subscriptionName, resourceGroup, osType, osSku, agentVersion, lastStatusChange, location\n| order by lastStatusChange asc",
              "size": 0,
              "title": "Disconnected Servers",
              "showExportToExcel": true,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "Name",
                    "formatter": 13,
                    "formatOptions": {
                      "linkTarget": "Resource",
                      "showIcon": true
                    }
                  }
                ],
                "rowLimit": 2000,
                "filter": true
              }
            },
            "name": "health-disconnected-grid"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| extend extensionServiceStatus = tostring(properties.serviceStatuses.extensionService.status)\n| extend gcServiceStatus = tostring(properties.serviceStatuses.guestConfigurationService.status)\n| where extensionServiceStatus != 'Running' or gcServiceStatus != 'Running'\n| extend osType = tostring(properties.osType)\n| project Name = name, resourceGroup, osType, extensionServiceStatus, gcServiceStatus, Status = tostring(properties.status)\n| order by Name asc",
              "size": 0,
              "title": "Servers with Degraded Services",
              "showExportToExcel": true,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "Name",
                    "formatter": 13,
                    "formatOptions": {
                      "linkTarget": "Resource",
                      "showIcon": true
                    }
                  },
                  {
                    "columnMatch": "extensionServiceStatus|gcServiceStatus",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "Running",
                          "representation": "success",
                          "text": "{0}"
                        },
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "representation": "warning",
                          "text": "{0}"
                        }
                      ]
                    }
                  }
                ],
                "rowLimit": 2000,
                "filter": true
              }
            },
            "name": "health-degraded-services"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| extend licenseType = coalesce(tostring(properties.licenseProfile.licenseType), 'Not Set')\n| extend softwareAssurance = coalesce(tostring(properties.licenseProfile.softwareAssuranceCustomer), 'Unknown')\n| extend osType = tostring(properties.osType)\n| summarize ServerCount = count() by licenseType, softwareAssurance, osType\n| order by licenseType asc, softwareAssurance asc",
              "size": 0,
              "title": "License Compliance Summary",
              "showExportToExcel": true,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "ServerCount",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "blue"
                    }
                  }
                ],
                "rowLimit": 500,
                "filter": true
              }
            },
            "name": "health-license-grid"
          }
        ]
      },
      "conditionalVisibility": {
        "parameterName": "selectedTab",
        "comparison": "isEqualTo",
        "value": "agenthealth"
      },
      "name": "tab-agenthealth"
    }
  ],
  "fallbackResourceIds": [
    "azure monitor"
  ],
  "$schema": "https://github.com/Microsoft/Application-Insights-Workbooks/blob/master/schema/workbook.json"
}