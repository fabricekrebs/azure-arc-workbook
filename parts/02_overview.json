          "name": "tile-win-versions"
        },
        {
          "type": 3,
          "content": {
            "version": "KqlItem/1.0",
            "query": "resources\n| where type == 'microsoft.azurearcdata/sqlserverinstances'\n| extend ver = tostring(properties.version)\n| extend Version = case(\n    ver contains '2012', 'SQL 2012',\n    ver contains '2014', 'SQL 2014',\n    ver contains '2016', 'SQL 2016',\n    ver contains '2017', 'SQL 2017',\n    ver contains '2019', 'SQL 2019',\n    ver contains '2022', 'SQL 2022',\n    ver contains '2025', 'SQL 2025',\n    'SQL Other')\n| summarize Count = count() by Version\n| order by Version asc",
            "size": 4,
            "title": "SQL Server Versions",
            "queryType": 1,
            "resourceType": "microsoft.resourcegraph/resources",
            "crossComponentResources": [
              "{Subscriptions}"
            ],
            "visualization": "tiles",
            "tileSettings": {
              "titleContent": {
                "columnMatch": "Version",
                "formatter": 1
              },
