          "name": "chart-os-type"
        },
        {
          "type": 3,
          "content": {
            "version": "KqlItem/1.0",
            "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| extend osSku = tostring(properties.osSku)\n| extend osType = tostring(properties.osType)\n| where osType == 'windows'\n| extend shortOsSku = replace_string(osSku, 'Windows Server', '')\n| summarize ServerCount = count() by shortOsSku\n| order by shortOsSku asc",
            "size": 3,
            "title": "Windows Server by OS",
            "queryType": 1,
            "resourceType": "microsoft.resourcegraph/resources",
            "crossComponentResources": [
              "{Subscriptions}"
            ],
            "visualization": "barchart"
          },
          "customWidth": "33",
          "name": "chart-win-os"
        },
        {
          "type": 3,
          "content": {
            "version": "KqlItem/1.0",
            "query": "resources\n| where type == 'microsoft.azurearcdata/sqlserverinstances'\n| extend SQLVersion = tostring(properties.version)\n| summarize Count = count() by SQLVersion\n| order by SQLVersion asc",
            "size": 3,
            "title": "SQL Instances by Version",
            "queryType": 1,
            "resourceType": "microsoft.resourcegraph/resources",
            "crossComponentResources": [
              "{Subscriptions}"
            ],
            "visualization": "barchart"
          },
          "customWidth": "33",
          "name": "chart-sql-version"
        },
        {
          "type": 3,
          "content": {
            "version": "KqlItem/1.0",
            "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| extend osSku = tostring(properties.osSku)\n| extend osType = tostring(properties.osType)\n| where osType == 'linux'\n| summarize ServerCount = count() by osSku\n| order by osSku asc",
            "size": 3,
            "title": "Linux Servers by OS",
            "queryType": 1,
            "resourceType": "microsoft.resourcegraph/resources",
            "crossComponentResources": [
              "{Subscriptions}"
            ],
            "visualization": "barchart"
          },
          "customWidth": "50",
          "name": "chart-linux-os"
        },
        {
          "type": 3,
          "content": {
            "version": "KqlItem/1.0",
            "query": "resources\n| where type == 'microsoft.hybridcompute/machines'\n| extend osSku = tostring(properties.osSku)\n| extend mssqlDiscovered = properties.mssqlDiscovered\n| join kind=inner (\n    resourcecontainers\n    | where type == 'microsoft.resources/subscriptions'\n    | project subscriptionId, subscriptionName = name\n) on subscriptionId\n| extend SQLFound = iff(mssqlDiscovered == 'true', 1, 0)\n| summarize ServerCount = count(), SQLServerCount = sum(SQLFound) by subscriptionName, resourceGroup, osSku\n| order by subscriptionName asc, resourceGroup asc, osSku asc",
            "size": 0,
            "title": "Servers per Subscription & Resource Group",
            "showExportToExcel": true,
            "queryType": 1,
            "resourceType": "microsoft.resourcegraph/resources",
            "crossComponentResources": [
              "{Subscriptions}"
            ],
            "gridSettings": {
              "rowLimit": 1000,
              "filter": true
            }
          },
          "customWidth": "50",
          "name": "grid-servers-per-sub"
        }
